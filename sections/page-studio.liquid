{% comment %}
  Studio — same layout as the Info page: slideshow + text panel, for showcasing the workspace.
{% endcomment %}

<section class="studio-page" data-section-id="{{ section.id }}">
  <div class="studio-page__frame">
    <div class="studio-page__track">

      {%- comment -%} ── Left: studio slideshow ── {%- endcomment -%}
      <div class="studio-page__card">
        <div class="studio-page__img-wrapper" id="studio-page-img-wrapper-{{ section.id }}">

          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'image' and block.settings.image != blank -%}
                <img
                  class="studio-page__img{% if forloop.first %} is-active{% endif %}"
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.image.alt | default: shop.name | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  {{ block.shopify_attributes }}
                >
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="studio-page__placeholder"></div>
          {%- endif -%}

          {%- assign image_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'image' and block.settings.image != blank -%}
              {%- assign image_count = image_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}

          <img
            class="studio-page__frame-img"
            src="{{ 'frame-3.png' | asset_url }}"
            alt=""
            aria-hidden="true"
            loading="eager"
          >

          {%- if image_count > 1 -%}
            <button class="studio-page__arrow studio-page__arrow--prev" type="button" aria-label="Previous image" data-arrow="prev">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11L5 7l4-4"/></svg>
            </button>
            <button class="studio-page__arrow studio-page__arrow--next" type="button" aria-label="Next image" data-arrow="next">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l4 4-4 4"/></svg>
            </button>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Right: studio text panel ── {%- endcomment -%}
      <div class="studio-page__bio">
        {%- if section.settings.name != blank -%}
          <h1 class="studio-page__name">{{ section.settings.name }}</h1>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="studio-page__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- if section.settings.bio != blank -%}
          <div class="studio-page__body">{{ section.settings.bio }}</div>
        {%- endif -%}

        {%- if section.settings.contact_label != blank and section.settings.contact_url != blank -%}
          <a class="studio-page__contact-link" href="{{ section.settings.contact_url }}">
            {{ section.settings.contact_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    height: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .studio-page {
    width: 100%;
    height: calc(100vh - clamp(2rem, 6vw, 6rem));
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .studio-page__frame {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .studio-page__track {
    display: flex;
    max-width: 1300px;
    width: 90%;
    gap: clamp(3rem, 8vw, 8rem);
    align-items: center;
    justify-content: center;
  }

  .studio-page__card {
    flex-shrink: 0;
    height: auto;
    width: clamp(340px, 42vw, 600px);
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    position: relative;
  }

  .studio-page__img-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: visible;
    position: relative;
  }

  .studio-page__placeholder {
    width: 100%;
    height: 100%;
    background: rgba(232, 226, 210, 0.06);
  }

  .studio-page__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 0.4s ease;
    overflow: hidden;
  }

  .studio-page__img.is-active {
    opacity: 1;
  }

  .studio-page__frame-img {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 5;
    display: block;
    transform: translate(-51%, -50%) scale(1.35);
  }

  .studio-page__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(13, 10, 7, 0.6);
    border: 1px solid rgba(232, 226, 210, 0.18);
    color: #e8e2d2;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease;
    z-index: 6;
    padding: 0;
  }

  .studio-page__img-wrapper:hover .studio-page__arrow:not([hidden]) {
    opacity: 1;
  }

  @media (hover: none) {
    .studio-page__img-wrapper .studio-page__arrow:not([hidden]) {
      opacity: 0.88;
    }
  }

  .studio-page__arrow:hover {
    background: rgba(13, 10, 7, 0.88);
  }

  .studio-page__arrow--prev { left: 0.6rem; }
  .studio-page__arrow--next { right: 0.6rem; }

  .studio-page__bio {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    max-width: 600px;
    padding: 1rem 0;
  }

  .studio-page__bio::-webkit-scrollbar { display: none; }

  .studio-page__name {
    font-family: 'TTHoves', sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: #e8e2d2;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .studio-page__tagline {
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    letter-spacing: 0.1em;
    color: rgba(232, 226, 210, 0.72);
    text-transform: lowercase;
    margin: 0;
  }

  .studio-page__body {
    font-size: clamp(0.78rem, 1.1vw, 0.92rem);
    line-height: 1.75;
    color: rgba(232, 226, 210, 0.92);
  }

  .studio-page__body p,
  .studio-page__body li,
  .studio-page__body ul,
  .studio-page__body ol {
    color: inherit;
  }

  .studio-page__body p {
    margin: 0 0 1em;
  }

  .studio-page__body p:last-child {
    margin-bottom: 0;
  }

  .studio-page__contact-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(232, 226, 210, 0.5);
    text-transform: lowercase;
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 226, 210, 0.2);
    padding-bottom: 0.15rem;
    transition: color 0.2s ease, border-color 0.2s ease;
    width: fit-content;
  }

  .studio-page__contact-link:hover {
    color: rgba(232, 226, 210, 0.85);
    border-color: rgba(232, 226, 210, 0.55);
  }

  @media (max-width: 749px) {
    .studio-page {
      height: auto;
      min-height: calc(100dvh - 6rem);
      align-items: flex-start;
      justify-content: flex-start;
      padding: 1rem 1.1rem calc(1.25rem + var(--maw-mobile-nav-clearance, 4rem) + env(safe-area-inset-bottom, 0px));
      box-sizing: border-box;
    }

    .studio-page__frame {
      height: auto;
      align-items: flex-start;
      overflow: visible;
    }

    .studio-page__track {
      flex-direction: column;
      width: 100%;
      max-width: none;
      gap: 1.35rem;
      align-items: stretch;
      justify-content: flex-start;
    }

    .studio-page__card {
      width: min(300px, 86vw);
      max-width: 100%;
      align-self: center;
      order: 0;
    }

    .studio-page__img-wrapper {
      aspect-ratio: 1 / 1;
      overflow: visible;
    }

    .studio-page__frame-img {
      transform: translate(-51%, -50%) scale(1.14);
    }

    .studio-page__arrow {
      display: none !important;
    }

    .studio-page__bio {
      flex: none;
      order: 1;
      max-width: none;
      padding: 0;
      justify-content: flex-start;
      gap: 1.1rem;
    }
  }
</style>

<script>
  (function () {
    var wrapper = document.getElementById('studio-page-img-wrapper-{{ section.id }}');
    if (!wrapper) return;

    var imgs    = wrapper.querySelectorAll('.studio-page__img');
    var prevBtn = wrapper.querySelector('[data-arrow="prev"]');
    var nextBtn = wrapper.querySelector('[data-arrow="next"]');
    if (imgs.length <= 1) return;

    var current = 0;
    var swipeMQ = window.matchMedia('(max-width: 749px)');
    var swipeStartX = 0;
    var swipeStartY = 0;
    var swipeTracking = false;
    var autoDelayMs = 6000;
    var autoTimer = null;

    function goTo(index) {
      imgs[current].classList.remove('is-active');
      current = index;
      imgs[current].classList.add('is-active');
    }

    function goPrev() {
      goTo(current === 0 ? imgs.length - 1 : current - 1);
    }

    function goNext() {
      goTo(current === imgs.length - 1 ? 0 : current + 1);
    }

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      autoTimer = setInterval(function () {
        if (!document.hidden) goNext();
      }, autoDelayMs);
    }

    if (prevBtn) prevBtn.addEventListener('click', goPrev);
    if (nextBtn) nextBtn.addEventListener('click', goNext);

    var SWIPE_MIN = 45;

    wrapper.addEventListener('touchstart', function (e) {
      if (!swipeMQ.matches || e.touches.length !== 1) return;
      swipeTracking = true;
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
    }, { passive: true });

    wrapper.addEventListener('touchmove', function (e) {
      if (!swipeTracking || !swipeMQ.matches) return;
      var t = e.touches[0];
      var dx = t.clientX - swipeStartX;
      var dy = t.clientY - swipeStartY;
      if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 12) swipeTracking = false;
    }, { passive: true });

    wrapper.addEventListener('touchend', function (e) {
      if (!swipeTracking || !swipeMQ.matches) {
        swipeTracking = false;
        return;
      }
      swipeTracking = false;
      var t = e.changedTouches[0];
      var dx = t.clientX - swipeStartX;
      var dy = t.clientY - swipeStartY;
      if (Math.abs(dx) < SWIPE_MIN || Math.abs(dx) < Math.abs(dy)) return;
      if (dx > 0) goPrev();
      else if (dx < 0) goNext();
    }, { passive: true });

    wrapper.addEventListener('touchcancel', function () {
      swipeTracking = false;
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Studio page",
  "settings": [
    {
      "type": "text",
      "id": "name",
      "label": "Heading",
      "default": "the studio"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Subheading",
      "default": "workspace"
    },
    {
      "type": "richtext",
      "id": "bio",
      "label": "Description",
      "default": "<p>Makayla’s studio is where patterns are drafted, fabrics are handled, and each garment is cut and sewn with care. Natural light, tools within reach, and room to work slowly define how each piece comes together.</p><p>Add photos of your bench, machines, materials, and the corners that make the space yours — the slideshow on the left is for those images.</p>"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Optional link label",
      "default": "get in touch"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Optional link URL"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Studio photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Studio page" }
  ]
}
{% endschema %}
