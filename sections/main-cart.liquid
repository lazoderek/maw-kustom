<section class="cart-page section" data-section-id="{{ section.id }}">
  <div class="cart-page__inner">
    <h1 class="cart-page__title" data-reveal="up">items</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form" class="cart-form">

        <div class="cart-items" id="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item" id="cart-item-{{ item.index | plus: 1 }}">

              <a href="{{ item.url }}" class="cart-item__image-wrap">
                <img
                  src="{{ item.image | image_url: width: 300 }}"
                  alt="{{ item.image.alt | default: item.title | escape }}"
                  width="120"
                  height="150"
                  loading="lazy"
                >
              </a>

              <div class="cart-item__info">
                <div class="cart-item__header">
                  <div>
                    <a href="{{ item.url }}" class="cart-item__title">{{ item.product_title }}</a>
                    {%- unless item.variant_title == 'Default Title' -%}
                      <p class="cart-item__variant">{{ item.variant_title }}</p>
                    {%- endunless -%}

                    {%- if item.properties.size > 0 -%}
                      <ul class="cart-item__properties">
                        {%- for p in item.properties -%}
                          {%- unless p.last == blank -%}
                            <li>
                              <span>{{ p.first }}:</span> {{ p.last }}
                            </li>
                          {%- endunless -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>

                  <button
                    type="button"
                    class="cart-item__remove"
                    aria-label="Remove {{ item.title }}"
                    onclick="removeCartItem('{{ item.key }}')"
                  >
                    remove
                  </button>
                </div>

                <div class="cart-item__footer">
                  <div class="cart-item__qty">
                    <button
                      type="button"
                      class="cart-item__qty-btn"
                      onclick="updateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})"
                      aria-label="Decrease quantity"
                    >−</button>
                    <span class="cart-item__qty-val">{{ item.quantity }}</span>
                    <button
                      type="button"
                      class="cart-item__qty-btn"
                      onclick="updateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})"
                      aria-label="Increase quantity"
                    >+</button>
                  </div>

                  <p class="cart-item__price">{{ item.final_line_price | money }}</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-footer">
          <div class="cart-footer__totals">
            <p class="cart-footer__label">subtotal</p>
            <p class="cart-footer__total">{{ cart.total_price | money }}</p>
          </div>
          <p class="cart-footer__note">shipping and taxes calculated at checkout.</p>

          <div class="cart-footer__actions">
            <button type="submit" name="checkout" class="cart-page__btn cart-page__btn--primary cart-footer__checkout">
              proceed to checkout
            </button>
            <a href="{{ routes.all_products_collection_url }}" class="cart-page__btn cart-page__btn--ghost">
              continue shopping
            </a>
          </div>
        </div>
      </form>

    {%- else -%}
      <div class="cart-empty" data-reveal="up">
        <p class="cart-empty__message">your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-page__btn cart-page__btn--primary cart-empty__cta">
          shop
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  @font-face {
    font-family: 'TTHoves';
    src: url('{{ 'TT-Hoves-Pro-Trial-Expanded-Light.ttf' | asset_url }}') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .cart-page {
    --cart-fg: #e8e2d2;
    --cart-fg-muted: rgba(232, 226, 210, 0.72);
    --cart-fg-soft: rgba(232, 226, 210, 0.5);
    --cart-border: rgba(232, 226, 210, 0.14);
    --cart-btn-bg: #271f16;
    --cart-btn-fg: #e8e2d2;
    color: var(--cart-fg);
    padding-block: clamp(2rem, 6vw, 4rem);
  }

  .cart-page__inner {
    width: 100%;
    max-width: 860px;
    margin-inline: auto;
    padding-inline: clamp(1.1rem, 4vw, 4rem);
    box-sizing: border-box;
  }

  .cart-page__title {
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    margin: 0 0 2.5rem;
    color: var(--cart-fg);
  }

  .cart-items {
    margin-bottom: 3rem;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--cart-border);
  }

  .cart-item__image-wrap {
    display: block;
    overflow: hidden;
    background: rgba(13, 10, 7, 0.35);
    border-radius: 4px;
  }

  .cart-item__image-wrap img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    display: block;
  }

  .cart-item__info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
  }

  .cart-item__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .cart-item__title {
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--cart-fg);
    text-decoration: none;
    display: block;
  }

  .cart-item__title:hover {
    color: #fff;
  }

  .cart-item__variant {
    font-size: 0.8rem;
    color: var(--cart-fg-muted);
    margin-top: 0.25rem;
    text-transform: lowercase;
  }

  .cart-item__properties {
    list-style: none;
    margin-top: 0.5rem;
    font-size: 0.78rem;
    color: var(--cart-fg-muted);
    line-height: 1.75;
  }

  .cart-item__remove {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--cart-fg-soft);
    background: none;
    border: none;
    border-bottom: 1px solid rgba(232, 226, 210, 0.22);
    cursor: pointer;
    padding: 0 0 0.1rem;
    white-space: nowrap;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .cart-item__remove:hover {
    color: var(--cart-fg);
    border-color: rgba(232, 226, 210, 0.5);
  }

  .cart-item__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid rgba(232, 226, 210, 0.22);
    padding: 0.25rem 0.75rem;
  }

  .cart-item__qty-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--cart-fg);
    padding: 0;
    line-height: 1;
  }

  .cart-item__qty-val {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    min-width: 1.5ch;
    text-align: center;
    color: var(--cart-fg);
  }

  .cart-item__price {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--cart-fg);
    text-transform: lowercase;
  }

  .cart-footer {
    border-top: 1px solid var(--cart-border);
    padding-top: 2rem;
  }

  .cart-footer__totals {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .cart-footer__label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    color: var(--cart-fg-muted);
  }

  .cart-footer__total {
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--cart-fg);
    text-transform: lowercase;
  }

  .cart-footer__note {
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--cart-fg-muted);
    margin-bottom: 1.5rem;
    text-transform: lowercase;
  }

  .cart-footer__actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .cart-page__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .cart-page__btn--primary {
    background: var(--cart-btn-bg);
    color: var(--cart-btn-fg);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: 0.95rem 1.75rem;
  }

  .cart-page__btn--primary:hover {
    background: #1a140f;
    color: #fff;
  }

  .cart-page__btn--ghost {
    background: transparent;
    color: var(--cart-fg);
    border: 1px solid rgba(232, 226, 210, 0.35);
    padding: 0.95rem 1.5rem;
  }

  .cart-page__btn--ghost:hover {
    border-color: rgba(232, 226, 210, 0.6);
    background: rgba(232, 226, 210, 0.06);
  }

  .cart-footer__checkout {
    flex: 1;
    min-width: min(100%, 14rem);
  }

  .cart-empty {
    padding: 4rem 0 6rem;
    text-align: center;
  }

  .cart-empty__message {
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    color: var(--cart-fg-muted);
    text-transform: lowercase;
    margin: 0;
  }

  .cart-empty__cta {
    margin-top: 2rem;
  }

  @media (max-width: 749px) {
    .cart-item {
      grid-template-columns: 96px 1fr;
      gap: 1rem;
    }

    .cart-item__image-wrap img {
      height: 120px;
    }

    .cart-footer__actions {
      flex-direction: column;
    }

    .cart-footer__checkout,
    .cart-page__btn--ghost {
      width: 100%;
    }
  }
</style>

<script>
  async function removeCartItem(key) {
    await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: 0 }),
    });
    window.MAW.refresh();
  }

  async function updateQty(key, qty) {
    if (qty < 0) return;
    await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty }),
    });
    window.MAW.refresh();
  }
</script>

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
