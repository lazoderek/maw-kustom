<section class="collection-strip section" data-section-id="{{ section.id }}">
  <div class="container">

    <div class="collection-strip__header" data-reveal="up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="collection-strip__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <div class="collection-strip__title-row">
        <h2 class="collection-strip__title">{{ section.settings.heading | default: 'The Collection' }}</h2>
        {%- if section.settings.view_all_url != blank -%}
          <a href="{{ section.settings.view_all_url }}" class="btn btn--text collection-strip__view-all">
            {{ section.settings.view_all_label | default: 'View all' }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- assign collection = collections[section.settings.collection] -%}

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="collection-strip__grid" data-reveal="up" data-reveal-stagger="0.1">
        {%- for product in collection.products limit: section.settings.product_count -%}
          <article class="product-card" data-reveal-child>
            <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}">
              <div class="product-card__image-wrap" data-parallax-wrap>
                {%- if product.featured_image != blank -%}
                  <img
                    class="product-card__image product-card__image--primary"
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    loading="lazy"
                    data-parallax="0.15"
                  >
                  {%- if product.images[1] != blank -%}
                    <img
                      class="product-card__image product-card__image--hover"
                      src="{{ product.images[1] | image_url: width: 800 }}"
                      alt="{{ product.images[1].alt | default: product.title | escape }}"
                      width="{{ product.images[1].width }}"
                      height="{{ product.images[1].height }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="product-card__image-placeholder"></div>
                {%- endif -%}

                <!-- Hover overlay -->
                <div class="product-card__overlay">
                  <span class="product-card__overlay-label btn btn--ghost">Quick view</span>
                </div>
              </div>

              <div class="product-card__info">
                <h3 class="product-card__title">{{ product.title }}</h3>
                <div class="product-card__meta">
                  {%- render 'product-price', product: product -%}
                  {%- if product.metafields.custom.order_type != blank -%}
                    <span class="product-card__type">{{ product.metafields.custom.order_type }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- Placeholder for theme editor when no collection is selected -->
      <div class="collection-strip__grid">
        {%- for i in (1..4) -%}
          <article class="product-card product-card--placeholder">
            <div class="product-card__image-wrap">
              <div class="product-card__image-placeholder"></div>
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Product name</h3>
              <p class="product-card__price">—</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .collection-strip__header {
    margin-bottom: 3rem;
  }

  .collection-strip__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-stitch);
    margin-bottom: 0.75rem;
  }

  .collection-strip__title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .collection-strip__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .collection-strip__view-all {
    font-size: 0.75rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Product grid ── */
  .collection-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  /* ── Product card ── */
  .product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--color-chalk);
  }

  .product-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 110%;
    object-fit: cover;
    transition: opacity 0.5s ease, transform 0.6s var(--ease-smooth);
  }

  .product-card__image--hover {
    opacity: 0;
  }

  .product-card:hover .product-card__image--primary {
    opacity: 0;
  }

  .product-card:hover .product-card__image--hover {
    opacity: 1;
  }

  .product-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-chalk) 0%, var(--color-dust) 100%);
    opacity: 0.4;
  }

  .product-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: linear-gradient(to top, rgba(17,17,16,0.35) 0%, transparent 60%);
  }

  .product-card:hover .product-card__overlay {
    opacity: 1;
  }

  .product-card__overlay-label {
    font-size: 0.7rem;
    padding: 0.6rem 1.4rem;
    border-color: rgba(255,255,255,0.6);
    color: var(--color-cream);
    background: rgba(17,17,16,0.25);
  }

  .product-card__info {
    padding-top: 1rem;
  }

  .product-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.5vw, 1.3rem);
    font-weight: 400;
    margin-bottom: 0.35rem;
    transition: color 0.2s;
  }

  .product-card:hover .product-card__title {
    color: var(--color-stitch);
  }

  .product-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .product-card__price {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }

  .product-card__type {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dust);
    border: 1px solid var(--color-dust);
    padding: 0.2rem 0.5rem;
    border-radius: 1px;
  }

  /* Placeholder state */
  .product-card--placeholder .product-card__image-placeholder {
    animation: shimmer 1.8s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 0.5; }
  }
</style>

{% schema %}
{
  "name": "Collection Strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Ready to wear"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Collection Strip"
    }
  ]
}
{% endschema %}
