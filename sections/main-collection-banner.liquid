<div class="collection-banner" data-section-id="{{ section.id }}">
  <div class="collection-banner__inner" {% if collection.image %}data-parallax-wrap{% endif %}>
    {%- if collection.image -%}
      <div class="collection-banner__image" data-parallax="0.3">
        <img
          src="{{ collection.image | image_url: width: 2000 }}"
          alt="{{ collection.image.alt | default: collection.title | escape }}"
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
          loading="eager"
        >
      </div>
      <div class="collection-banner__overlay"></div>
    {%- endif -%}

    <div class="container collection-banner__content" {% unless collection.image %}style="padding-top:8rem;padding-bottom:3rem;"{% endunless %}>
      <p class="collection-banner__eyebrow" data-reveal="up">Collection</p>
      <h1 class="collection-banner__title" data-reveal="up" data-reveal-delay="0.1">{{ collection.title }}</h1>
      {%- if section.settings.show_collection_description and collection.description != blank -%}
        <div class="collection-banner__desc" data-reveal="up" data-reveal-delay="0.2">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .collection-banner {
    position: relative;
    overflow: hidden;
    margin-top: 72px;
    background: var(--color-chalk);
  }

  .collection-banner__inner {
    position: relative;
    min-height: 36vh;
    display: flex;
    align-items: flex-end;
  }

  .collection-banner__image {
    position: absolute;
    inset: -10%;
  }

  .collection-banner__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .collection-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,16,0.6) 0%, transparent 60%);
  }

  .collection-banner__content {
    position: relative;
    z-index: 2;
    padding-top: 5rem;
    padding-bottom: 3rem;
    color: var(--color-cream);
  }

  .collection-banner:not(:has(.collection-banner__image)) .collection-banner__content {
    color: var(--color-ink);
  }

  .collection-banner__eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }

  .collection-banner__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
  }

  .collection-banner__desc {
    max-width: 60ch;
    margin-top: 1rem;
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "Show collection description",
      "default": true
    }
  ]
}
{% endschema %}
