{% comment %}
  Global navigation banner — sole site nav.
  Pinned just above the bottom of the viewport via flex layout in theme.liquid.
  Layout (left → right):
    1. Wordmark
    2. Vertical list of nav links
    3. Wide editorial copy panel
    4. (Optional) cart / account icons (tablet/desktop; hidden on phone)
  Phone (≤749px): CSS grid 1fr / auto / 1fr — mobile logo (start), links (center),
    rounded cart count pill (end). Pill is hidden when the cart is empty.
{% endcomment %}

{%- liquid
  comment
    One opaque color for Safari/Android chrome + nav bar so the UI bars match the bar (no translucent vs opaque mismatch).
  endcomment
  assign bar_fill = settings.browser_chrome_color | default: section.settings.bg_color | default: '#271f16'
  assign mobile_logo_url = ''
  if section.settings.mobile_logo != blank
    assign mobile_logo_url = section.settings.mobile_logo | image_url: width: 480
  endif
  if mobile_logo_url == blank
    assign mobile_logo_url = 'mobile-logo.png' | file_img_url: width: 480
  endif
-%}

<div class="nav-banner-stack">
<nav
  class="nav-banner"
  role="navigation"
  aria-label="Site navigation"
  data-section-id="{{ section.id }}"
  style="
    --nav-bg:   {{ bar_fill }};
    --nav-fg:   {{ section.settings.text_color  | default: '#e8e2d2' }};
    --nav-mute: {{ section.settings.muted_color | default: '#7a6f5d' }};
  "
>
  <!-- Column 1 — Wordmark -->
  <div class="nav-banner__brand">
    <a href="{{ routes.root_url }}" class="nav-banner__wordmark-link" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          loading="lazy"
          class="nav-banner__logo-img"
        >
      {%- else -%}
        <span class="nav-banner__wordmark">{{ section.settings.wordmark | default: 'MAW' }}</span>
      {%- endif -%}
    </a>
  </div>

  {%- if mobile_logo_url != blank -%}
    <a href="{{ routes.root_url }}" class="nav-banner__mobile-logo-link" aria-label="{{ shop.name }}">
      <img
        class="nav-banner__mobile-logo-img"
        src="{{ mobile_logo_url }}"
        alt="{{ shop.name }}"
        loading="eager"
        decoding="async"
      >
    </a>
  {%- endif -%}

  <!-- Column 2 — Vertical nav links -->
  {%- comment -%}
    Render priority pages (info → studio → works) first in this exact order,
    then any remaining menu links (e.g. the products / collection link) after.
    Contact is hidden site-wide here; manage it via Shopify admin → Navigation if
    you want it elsewhere.
  {%- endcomment -%}
  {%- assign nav_priority_handles = 'info,studio,works' | split: ',' -%}
  <ul class="nav-banner__links">
    {%- for handle in nav_priority_handles -%}
      {%- for link in section.settings.menu.links -%}
        {%- assign nav_link_title_down = link.title | downcase | strip -%}
        {%- if link.handle == handle or nav_link_title_down == handle -%}
          <li>
            <a
              href="{{ link.url }}"
              class="nav-banner__link"
              {% if link.active %}aria-current="page"{% endif %}
            >{{ link.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}

    {%- for link in section.settings.menu.links -%}
      {%- assign nav_link_title_down = link.title | downcase | strip -%}
      {%- if link.handle == 'contact' or nav_link_title_down == 'contact' -%}
        {%- continue -%}
      {%- endif -%}
      {%- if nav_priority_handles contains link.handle -%}{%- continue -%}{%- endif -%}
      {%- if nav_priority_handles contains nav_link_title_down -%}{%- continue -%}{%- endif -%}
      <li>
        <a
          href="{{ link.url }}"
          class="nav-banner__link"
          {% if link.active %}aria-current="page"{% endif %}
        >{{ link.title }}</a>
      </li>
    {%- endfor -%}
  </ul>

  <!-- Mobile-only: cart count pill (hidden when empty; theme.js updateCartCount) -->
  <a
    href="{{ routes.cart_url }}"
    class="nav-banner__cart-pill"
    data-cart-count
    aria-label="{% if cart.item_count > 0 -%}Cart, {{ cart.item_count }} {%- if cart.item_count == 1 -%}item{%- else -%}items{%- endif -%}{%- else -%}Cart{%- endif -%}"
    {% if cart.item_count == 0 %}hidden{% endif %}
  >{{ cart.item_count }}</a>

  <!-- Column 3 — Editorial copy panel (swapped for stockists list on the product/collection page) -->
  {%- assign is_collection_template = false -%}
  {%- if template.name == 'collection' -%}
    {%- assign is_collection_template = true -%}
  {%- endif -%}

  {%- if is_collection_template and settings.stockists != blank -%}
    <div class="nav-banner__panel nav-banner__panel--stockists">
      {%- if settings.stockists_heading != blank -%}
        <h2 class="nav-banner__panel-heading">{{ settings.stockists_heading }}</h2>
      {%- endif -%}
      <div class="nav-banner__panel-body">{{ settings.stockists }}</div>
    </div>
  {%- elsif section.settings.show_panel_text and section.settings.panel_text != blank -%}
    <div class="nav-banner__panel">{{ section.settings.panel_text }}</div>
  {%- endif -%}

  <!-- Column 4 — Account / cart -->
  {%- if section.settings.show_actions -%}
    <div class="nav-banner__actions">
      <a href="{{ routes.cart_url }}" class="nav-banner__action" aria-label="Cart">
        {%- render 'icon-bag' -%}
        <span data-cart-count hidden>0</span>
      </a>
      <a href="{{ routes.account_url }}" class="nav-banner__action" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>
    </div>
  {%- endif -%}
</nav>
</div>

<style>
  @font-face {
    font-family: 'TTHoves';
    src: url('{{ 'TT-Hoves-Pro-Trial-Expanded-Light.ttf' | asset_url }}') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .nav-banner {
    flex-shrink: 0;
    display: grid;
    grid-template-columns: minmax(180px, auto) auto 1fr auto;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(1.25rem, 2.5vw, 2rem) clamp(1.5rem, 4vw, 4rem);
    background: {{ bar_fill }};
    color: var(--nav-fg);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    position: relative;
    isolation: isolate;
    margin: clamp(1rem, 3vw, 3rem) 0 2rem;
    /* Fixed typography root so nav copy stays the same when html font-size drops on mobile. */
    font-size: 16px;
  }

  /* Fixed bottom stack on phone only; normal block layout on larger breakpoints */
  .nav-banner-stack {
    flex-shrink: 0;
  }

  /* Inline mobile bar logo — hidden on large screens */
  .nav-banner__mobile-logo-link {
    display: none;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: inherit;
    margin: 0;
    padding: 0;
  }

  .nav-banner__mobile-logo-img {
    display: block;
    height: 1.85rem;
    width: auto;
    max-width: 4.75rem;
    object-fit: contain;
    object-position: left center;
  }

  /* Mobile-only cart (desktop / tablet use optional icon actions) */
  .nav-banner__cart-pill {
    display: none;
  }

  /* ── Column 1 — Brand ── */
  .nav-banner__brand {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .nav-banner__wordmark-link { display: inline-block; }

  .nav-banner__wordmark {
    font-family: var(--font-serif), Georgia, serif;
    font-size: clamp(2.75em, 5vw, 4.5em);
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.02em;
    line-height: 0.85;
    color: var(--nav-fg);
    text-shadow:
      2px 2px 0 rgba(0,0,0,0.35),
      0 0 1px rgba(255,255,255,0.05);
    /* slight rough/torn vibe */
    -webkit-text-stroke: 1px rgba(255,255,255,0.04);
  }

  .nav-banner__logo-img {
    max-height: clamp(80px, 9vw, 140px);
    width: auto;
    object-fit: contain;
    object-position: left center;
  }

  /* ── Column 2 — Links ── */
  .nav-banner__links {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: none;
    padding-left: clamp(1rem, 2vw, 2rem);
  }

  .nav-banner__link {
    /* font-family: var(--font-sans); */
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: clamp(0.78em, 1vw, 0.95em);
    letter-spacing: 0.04em;
    color: var(--nav-fg);
    line-height: 1.7;
    text-transform: lowercase;
    display: inline-block;
    padding-inline: 0.3em;
    transition: color 0.2s ease;
  }

  .nav-banner__link[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 0.22em;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(232, 226, 210, 0.65);
  }

  /* ── Column 3 — Editorial copy panel ── */
  .nav-banner__panel {
    align-self: center;
    border-left: none;
    padding-left: clamp(1rem, 2vw, 2rem);
    font-family: var(--font-sans);
    font-size: clamp(0.7em, 0.85vw, 0.82em);
    line-height: 1.65;
    color: var(--nav-mute);
    column-count: 2;
    column-gap: 2rem;
    max-width: 70ch;
  }

  .nav-banner__panel p { margin: 0 0 0.5em; color: inherit; font-size: inherit; line-height: inherit; }
  .nav-banner__panel p:last-child { margin-bottom: 0; }

  /* ── Stockists variant (collection page only) ── */
  .nav-banner__panel--stockists {
    column-count: 1;
    max-width: 28ch;
    color: var(--nav-fg);
  }

  .nav-banner__panel-heading {
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: 0.62em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--nav-fg);
    margin: 0 0 0.55em;
    font-weight: 400;
  }

  .nav-banner__panel--stockists .nav-banner__panel-body :where(p, li, span, div) {
    color: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .nav-banner__panel--stockists .nav-banner__panel-body p {
    margin: 0 0 0.18em;
  }

  .nav-banner__panel--stockists .nav-banner__panel-body p:last-child {
    margin-bottom: 0;
  }

  .nav-banner__panel--stockists .nav-banner__panel-body a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(232, 226, 210, 0.25);
    text-underline-offset: 0.18em;
    transition: text-decoration-color 0.2s ease;
  }

  .nav-banner__panel--stockists .nav-banner__panel-body a:hover {
    text-decoration-color: rgba(232, 226, 210, 0.65);
  }

  /* ── Column 4 — Actions ── */
  .nav-banner__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    align-self: center;
  }

  .nav-banner__action {
    position: relative;
    display: flex;
    align-items: center;
    color: var(--nav-mute);
    transition: color 0.2s;
  }

  .nav-banner__action:hover { color: var(--nav-fg); }

  .nav-banner__action svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
  }

  .nav-banner__action [data-cart-count] {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--nav-fg);
    color: var(--nav-bg);
    font-size: 0.55em;
    font-weight: 600;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .nav-banner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 1rem 1.5rem;
      padding: 1rem 1.25rem;
    }

    .nav-banner__brand {
      grid-column: 1;
      grid-row: 1;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
    }

    .nav-banner__links {
      grid-column: 1 / -1;
      grid-row: 2;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.25rem 1.5rem;
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-left: 0;
      padding-top: 0.75rem;
    }

    .nav-banner__panel { display: none; }

    .nav-banner__actions {
      grid-column: 2;
      grid-row: 1;
    }
  }

  /* ── Fixed phone bar: logo + links as a centered cluster ── */
  @media (max-width: 749px) {
    .nav-banner-stack {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 5000;
      pointer-events: none;
    }

    .nav-banner-stack > * {
      pointer-events: auto;
    }

    .nav-banner {
      position: relative;
      margin: 0;
      width: 100%;
      box-sizing: border-box;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: 0.5rem;
      min-height: 3rem;
      padding-top: 0.5rem;
      padding-left: max(1rem, env(safe-area-inset-left, 0px));
      padding-right: max(1rem, env(safe-area-inset-right, 0px));
      padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(10px);
    }

    .nav-banner__mobile-logo-link {
      display: flex;
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
      align-self: center;
      margin: 0;
    }

    /* Hide logo / wordmark on small screens for a slimmer bar */
    .nav-banner__brand {
      display: none;
    }

    .nav-banner__links {
      grid-column: 2;
      grid-row: 1;
      justify-self: center;
      align-self: center;
      min-width: 0;
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      align-content: center;
      gap: 0.25rem 0.4rem;
      border-top: none;
      padding: 0 0 0 1.65rem;
      margin: 0;
      list-style: none;
      width: auto;
      max-width: 100%;
    }

    .nav-banner__links > li {
      display: flex;
      align-items: center;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .nav-banner__link {
      font-size: 0.72em;
      line-height: 1;
      text-transform: lowercase;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.35rem 0.45rem;
      margin: 0;
      box-sizing: border-box;
    }

    .nav-banner__link[aria-current="page"] {
      text-underline-offset: 0.12em;
    }

    .nav-banner__cart-pill {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
      align-self: center;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
      min-width: 1.75rem;
      padding: 0.28rem 0.5rem;
      border-radius: 0.375rem;
      font-family: 'TTHoves', var(--font-sans), sans-serif;
      font-size: 0.72em;
      font-variant-numeric: tabular-nums;
      line-height: 1;
      color: var(--nav-fg);
      text-decoration: none;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .nav-banner__cart-pill[hidden] {
      display: none !important;
    }

    .nav-banner__cart-pill:hover {
      background: rgba(255, 255, 255, 0.22);
      color: var(--nav-fg);
    }

    .nav-banner__cart-pill:focus-visible {
      outline: 2px solid var(--nav-fg);
      outline-offset: 2px;
    }

    /* Icon row is for tablet/desktop only */
    .nav-banner__actions {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Navigation banner",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark text",
      "info": "Used when no logo image is set.",
      "default": "MAW"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (optional)",
      "info": "Overrides the wordmark text."
    },
    {
      "type": "image_picker",
      "id": "mobile_logo",
      "label": "Mobile logo",
      "info": "Left of the menu links in the small-screen bar. If empty, theme looks for Files upload mobile-logo.png."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Editorial panel"
    },
    {
      "type": "richtext",
      "id": "panel_text",
      "label": "Panel text",
      "default": "<p>Custom garments designed and sewn by hand from our studio. Made to order in small batches with intention, restraint, and a respect for the craft.</p><p>Each piece is built to outlast the season — repaired, re-loved, and worn for years.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_panel_text",
      "label": "Show editorial panel",
      "default": false,
      "info": "Desktop nav column. Stockists still appear on the product collection page when configured in theme settings."
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Banner background",
      "default": "#271f16"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Foreground text",
      "default": "#e8e2d2"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#7a6f5d"
    },
    {
      "type": "header",
      "content": "Actions"
    },
    {
      "type": "checkbox",
      "id": "show_actions",
      "label": "Show cart & account icons",
      "default": false
    }
  ]
}
{% endschema %}
