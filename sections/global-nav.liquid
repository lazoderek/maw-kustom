{% comment %}
  Global navigation banner — sole site nav.
  Pinned just above the bottom of the viewport via flex layout in theme.liquid.
  Layout (left → right):
    1. Wordmark + tiny copyright line
    2. Vertical list of nav links
    3. Wide editorial copy panel
    4. (Optional) cart / account icons
  Phone: optional compact logo image at left of the same bar as links.
{% endcomment %}

{%- liquid
  comment
    One opaque color for Safari/Android chrome + nav bar so the UI bars match the bar (no translucent vs opaque mismatch).
  endcomment
  assign bar_fill = settings.browser_chrome_color | default: section.settings.bg_color | default: '#271f16'
  assign mobile_logo_url = ''
  if section.settings.mobile_logo != blank
    assign mobile_logo_url = section.settings.mobile_logo | image_url: width: 480
  endif
  if mobile_logo_url == blank
    assign mobile_logo_url = 'mobile-logo.png' | file_img_url: width: 480
  endif
-%}

<div class="nav-banner-stack">
<nav
  class="nav-banner"
  role="navigation"
  aria-label="Site navigation"
  data-section-id="{{ section.id }}"
  style="
    --nav-bg:   {{ bar_fill }};
    --nav-fg:   {{ section.settings.text_color  | default: '#e8e2d2' }};
    --nav-mute: {{ section.settings.muted_color | default: '#7a6f5d' }};
  "
>
  <!-- Column 1 — Wordmark + copyright -->
  <div class="nav-banner__brand">
    <a href="{{ routes.root_url }}" class="nav-banner__wordmark-link" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          loading="lazy"
          class="nav-banner__logo-img"
        >
      {%- else -%}
        <span class="nav-banner__wordmark">{{ section.settings.wordmark | default: 'MAW' }}</span>
      {%- endif -%}
    </a>
    <p class="nav-banner__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.legal_text != blank %} &nbsp;{{ section.settings.legal_text }}{% endif %}
    </p>
  </div>

  {%- if mobile_logo_url != blank -%}
    <a href="{{ routes.root_url }}" class="nav-banner__mobile-logo-link" aria-label="{{ shop.name }}">
      <img
        class="nav-banner__mobile-logo-img"
        src="{{ mobile_logo_url }}"
        alt="{{ shop.name }}"
        loading="eager"
        decoding="async"
      >
    </a>
  {%- endif -%}

  <!-- Column 2 — Vertical nav links -->
  <ul class="nav-banner__links">
    {%- for link in section.settings.menu.links -%}
      <li>
        <a
          href="{{ link.url }}"
          class="nav-banner__link"
          {% if link.active %}aria-current="page"{% endif %}
        >{{ link.title }}</a>
      </li>
    {%- endfor -%}
  </ul>

  <!-- Column 3 — Editorial copy panel -->
  {%- if section.settings.panel_text != blank -%}
    <div class="nav-banner__panel">{{ section.settings.panel_text }}</div>
  {%- endif -%}

  <!-- Column 4 — Account / cart -->
  {%- if section.settings.show_actions -%}
    <div class="nav-banner__actions">
      <a href="{{ routes.cart_url }}" class="nav-banner__action" aria-label="Cart">
        {%- render 'icon-bag' -%}
        <span data-cart-count hidden>0</span>
      </a>
      <a href="{{ routes.account_url }}" class="nav-banner__action" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>
    </div>
  {%- endif -%}
</nav>
</div>

<style>
  @font-face {
    font-family: 'TTHoves';
    src: url('{{ 'TT-Hoves-Pro-Trial-Expanded-Light.ttf' | asset_url }}') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .nav-banner {
    flex-shrink: 0;
    display: grid;
    grid-template-columns: minmax(180px, auto) auto 1fr auto;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(1.25rem, 2.5vw, 2rem) clamp(1.5rem, 4vw, 4rem);
    background: {{ bar_fill }};
    color: var(--nav-fg);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    position: relative;
    isolation: isolate;
    margin: clamp(1rem, 3vw, 3rem) 0 2rem;
    /* Fixed typography root so nav copy stays the same when html font-size drops on mobile. */
    font-size: 16px;
  }

  /* Fixed bottom stack on phone only; normal block layout on larger breakpoints */
  .nav-banner-stack {
    flex-shrink: 0;
  }

  /* Inline mobile bar logo — hidden on large screens */
  .nav-banner__mobile-logo-link {
    display: none;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: inherit;
    margin: 0;
    padding: 0;
  }

  .nav-banner__mobile-logo-img {
    display: block;
    height: 1.85rem;
    width: auto;
    max-width: 4.75rem;
    object-fit: contain;
    object-position: left center;
  }

  /* ── Column 1 — Brand ── */
  .nav-banner__brand {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .nav-banner__wordmark-link { display: inline-block; }

  .nav-banner__wordmark {
    font-family: var(--font-serif), Georgia, serif;
    font-size: clamp(2.75em, 5vw, 4.5em);
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.02em;
    line-height: 0.85;
    color: var(--nav-fg);
    text-shadow:
      2px 2px 0 rgba(0,0,0,0.35),
      0 0 1px rgba(255,255,255,0.05);
    /* slight rough/torn vibe */
    -webkit-text-stroke: 1px rgba(255,255,255,0.04);
  }

  .nav-banner__logo-img {
    max-height: clamp(80px, 9vw, 140px);
    width: auto;
    object-fit: contain;
    object-position: left center;
  }

  .nav-banner__copyright {
    font-family: var(--font-sans);
    font-size: 0.6em;
    letter-spacing: 0.08em;
    color: var(--nav-mute);
    line-height: 1.4;
    margin-top: auto;
  }

  /* ── Column 2 — Links ── */
  .nav-banner__links {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: none;
    padding-left: clamp(1rem, 2vw, 2rem);
  }

  .nav-banner__link {
    /* font-family: var(--font-sans); */
    font-family: 'TTHoves', var(--font-sans), sans-serif;
    font-size: clamp(0.78em, 1vw, 0.95em);
    letter-spacing: 0.04em;
    color: var(--nav-fg);
    line-height: 1.7;
    /* transition: color 0.2s ease, transform 0.25s ease; */
    text-transform: lowercase;
    display: inline-block;
    padding-inline: 0.3em;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .nav-banner__link:hover {
    background-color: var(--nav-fg);
    color: var(--nav-bg);
    padding-inline: 0.3em;
  }

  .nav-banner__link[aria-current="page"] {
    background-color: var(--nav-fg);
    color: var(--nav-bg);
    padding-inline: 0.3em;
  }

  /* ── Column 3 — Editorial copy panel ── */
  .nav-banner__panel {
    align-self: center;
    border-left: none;
    padding-left: clamp(1rem, 2vw, 2rem);
    font-family: var(--font-sans);
    font-size: clamp(0.7em, 0.85vw, 0.82em);
    line-height: 1.65;
    color: var(--nav-mute);
    column-count: 2;
    column-gap: 2rem;
    max-width: 70ch;
  }

  .nav-banner__panel p { margin: 0 0 0.5em; color: inherit; font-size: inherit; line-height: inherit; }
  .nav-banner__panel p:last-child { margin-bottom: 0; }

  /* ── Column 4 — Actions ── */
  .nav-banner__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    align-self: center;
  }

  .nav-banner__action {
    position: relative;
    display: flex;
    align-items: center;
    color: var(--nav-mute);
    transition: color 0.2s;
  }

  .nav-banner__action:hover { color: var(--nav-fg); }

  .nav-banner__action svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
  }

  .nav-banner__action [data-cart-count] {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--nav-fg);
    color: var(--nav-bg);
    font-size: 0.55em;
    font-weight: 600;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .nav-banner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 1rem 1.5rem;
      padding: 1rem 1.25rem;
    }

    .nav-banner__brand {
      grid-column: 1;
      grid-row: 1;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
    }

    .nav-banner__copyright { margin-top: 0; }

    .nav-banner__links {
      grid-column: 1 / -1;
      grid-row: 2;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.25rem 1.5rem;
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-left: 0;
      padding-top: 0.75rem;
    }

    .nav-banner__panel { display: none; }

    .nav-banner__actions {
      grid-column: 2;
      grid-row: 1;
    }
  }

  /* ── Fixed phone bar: logo + links as a centered cluster ── */
  @media (max-width: 749px) {
    .nav-banner-stack {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 5000;
      pointer-events: none;
    }

    .nav-banner-stack > * {
      pointer-events: auto;
    }

    .nav-banner {
      position: relative;
      margin: 0;
      width: 100%;
      box-sizing: border-box;
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      padding-top: 0.5rem;
      padding-left: max(1rem, env(safe-area-inset-left, 0px));
      padding-right: max(1rem, env(safe-area-inset-right, 0px));
      padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(10px);
    }

    /* Space before links (flex gap is flaky on some iOS versions) */
    .nav-banner__mobile-logo-link {
      display: flex;
      margin-inline-end: 1rem;
    }

    .nav-banner:has(.nav-banner__actions) {
      padding-right: max(2.65rem, calc(0.65rem + env(safe-area-inset-right, 0px)));
    }

    /* Hide logo / wordmark on small screens (copyright lives here too—omitted for a slimmer bar) */
    .nav-banner__brand {
      display: none;
    }

    .nav-banner__links {
      flex: 0 1 auto;
      align-self: stretch;
      min-height: 0;
      min-width: 0;
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
      align-items: center;
      align-content: center;
      gap: 0.25rem 0.4rem;
      border-top: none;
      padding: 0;
      margin: 0;
      list-style: none;
      width: auto;
      max-width: none;
    }

    .nav-banner__links > li {
      display: flex;
      align-items: center;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .nav-banner__link {
      font-size: 0.72em;
      line-height: 1;
      text-transform: lowercase;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.35rem 0.45rem;
      margin: 0;
      box-sizing: border-box;
    }

    .nav-banner__actions {
      position: absolute;
      right: max(0.65rem, env(safe-area-inset-right, 0px));
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }
  }
</style>

{% schema %}
{
  "name": "Navigation banner",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark text",
      "info": "Used when no logo image is set.",
      "default": "MAW"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (optional)",
      "info": "Overrides the wordmark text."
    },
    {
      "type": "image_picker",
      "id": "mobile_logo",
      "label": "Mobile logo",
      "info": "Left of the menu links in the small-screen bar. If empty, theme looks for Files upload mobile-logo.png."
    },
    {
      "type": "text",
      "id": "legal_text",
      "label": "Legal text (after copyright)",
      "default": "All rights reserved."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Editorial panel"
    },
    {
      "type": "richtext",
      "id": "panel_text",
      "label": "Panel text",
      "default": "<p>Custom garments designed and sewn by hand from our studio. Made to order in small batches with intention, restraint, and a respect for the craft.</p><p>Each piece is built to outlast the season — repaired, re-loved, and worn for years.</p>"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Banner background",
      "default": "#271f16"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Foreground text",
      "default": "#e8e2d2"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#7a6f5d"
    },
    {
      "type": "header",
      "content": "Actions"
    },
    {
      "type": "checkbox",
      "id": "show_actions",
      "label": "Show cart & account icons",
      "default": false
    }
  ]
}
{% endschema %}
