<section class="auth-page section" data-section-id="{{ section.id }}">
  <div class="container" style="max-width:480px;">
    <h1 class="auth-page__title" data-reveal="up">Reset password</h1>
    <p style="margin-bottom:2rem;color:var(--color-ink-soft);">Enter your email and we'll send you a reset link.</p>

    {%- form 'recover_customer_password', class: 'auth-form' -%}
      {%- if form.posted_successfully? -%}
        <p style="color:var(--color-stitch);font-style:italic;font-family:var(--font-serif);">Check your email — a reset link is on its way.</p>
      {%- else -%}
        <div class="auth-form__field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" autocomplete="email" required>
        </div>
        <div class="auth-form__actions">
          <button type="submit" class="btn btn--primary">Send reset link</button>
          <a href="{{ routes.account_login_url }}" class="auth-form__link">Back to login</a>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}{ "name": "Reset Password", "settings": [] }{% endschema %}
