{% comment %}
  Info page — same viewport shell as home-hero / all-products-horizontal.
  Mirrors all-products exactly: section → frame → track → columns.
{% endcomment %}

<section class="info-page" data-section-id="{{ section.id }}">
  <div class="info-page__frame">
    <div class="info-page__track">

      {%- comment -%} ── Left: image slideshow card ── {%- endcomment -%}
      <div class="info-page__card">
        <div class="info-page__img-wrapper" id="info-page-img-wrapper-{{ section.id }}">

          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'image' and block.settings.image != blank -%}
                <img
                  class="info-page__img{% if forloop.first %} is-active{% endif %}"
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.image.alt | default: shop.name | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  {{ block.shopify_attributes }}
                >
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="info-page__placeholder"></div>
          {%- endif -%}

          {%- assign image_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'image' and block.settings.image != blank -%}
              {%- assign image_count = image_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}

          <img
            class="info-page__frame-img"
            src="{{ 'frame-4.png' | asset_url }}"
            alt=""
            aria-hidden="true"
            loading="eager"
          >

          {%- if image_count > 1 -%}
            <button class="info-page__arrow info-page__arrow--prev" type="button" aria-label="Previous image" data-arrow="prev">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11L5 7l4-4"/></svg>
            </button>
            <button class="info-page__arrow info-page__arrow--next" type="button" aria-label="Next image" data-arrow="next">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l4 4-4 4"/></svg>
            </button>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Right: bio text panel ── {%- endcomment -%}
      <div class="info-page__bio">
        {%- if section.settings.name != blank -%}
          <h1 class="info-page__name">{{ section.settings.name }}</h1>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="info-page__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- if section.settings.bio != blank -%}
          <div class="info-page__body">{{ section.settings.bio }}</div>
        {%- endif -%}

        {%- if section.settings.show_instagram and section.settings.instagram_url != blank -%}
          <div class="info-page__social">
            <a
              class="info-page__social-link"
              href="{{ section.settings.instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ section.settings.instagram_label | default: 'Instagram' | escape }}"
            >
              {%- render 'icon-instagram' -%}
            </a>
          </div>
        {%- endif -%}

        {%- if section.settings.contact_label != blank and section.settings.contact_url != blank -%}
          <a class="info-page__contact-link" href="{{ section.settings.contact_url }}">
            {{ section.settings.contact_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    height: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .info-page {
    width: 100%;
    height: calc(100vh - clamp(2rem, 6vw, 6rem));
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .info-page__frame {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .info-page__track {
    display: flex;
    max-width: 1300px;
    width: 90%;
    gap: clamp(3rem, 8vw, 8rem);
    align-items: center;
    justify-content: center;
  }

  .info-page__card {
    flex-shrink: 0;
    height: auto;
    width: clamp(340px, 42vw, 600px);
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    position: relative;
  }

  .info-page__img-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: visible;
    position: relative;
  }

  .info-page__placeholder {
    width: 100%;
    height: 100%;
    background: rgba(232, 226, 210, 0.06);
  }

  .info-page__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 0.4s ease;
    overflow: hidden;
  }

  .info-page__img.is-active {
    opacity: 1;
  }

  .info-page__frame-img {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 5;
    display: block;
    transform: translate(-51%, -50%) scale(1.35);
  }

  .info-page__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(13, 10, 7, 0.6);
    border: 1px solid rgba(232, 226, 210, 0.18);
    color: #e8e2d2;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease;
    z-index: 6;
    padding: 0;
  }

  .info-page__img-wrapper:hover .info-page__arrow:not([hidden]) {
    opacity: 1;
  }

  @media (hover: none) {
    .info-page__img-wrapper .info-page__arrow:not([hidden]) {
      opacity: 0.88;
    }
  }

  .info-page__arrow:hover {
    background: rgba(13, 10, 7, 0.88);
  }

  .info-page__arrow--prev { left: 0.6rem; }
  .info-page__arrow--next { right: 0.6rem; }

  .info-page__bio {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    max-width: 600px;
    padding: 1rem 0;
  }

  .info-page__bio::-webkit-scrollbar { display: none; }

  .info-page__name {
    font-family: 'TTHoves', sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: #e8e2d2;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .info-page__tagline {
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    letter-spacing: 0.1em;
    color: rgba(232, 226, 210, 0.72);
    text-transform: lowercase;
    margin: 0;
  }

  .info-page__body {
    font-size: clamp(0.78rem, 1.1vw, 0.92rem);
    line-height: 1.75;
    color: rgba(232, 226, 210, 0.92);
  }

  .info-page__body p,
  .info-page__body li,
  .info-page__body ul,
  .info-page__body ol {
    color: inherit;
  }

  .info-page__body p {
    margin: 0 0 1em;
  }

  .info-page__body p:last-child {
    margin-bottom: 0;
  }

  .info-page__social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.1rem;
  }

  .info-page__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(232, 226, 210, 0.55);
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .info-page__social-link:hover {
    color: rgba(232, 226, 210, 0.9);
  }

  .info-page__social-link svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
  }

  .info-page__social-link svg circle[fill] {
    fill: currentColor;
  }

  .info-page__contact-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(232, 226, 210, 0.5);
    text-transform: lowercase;
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 226, 210, 0.2);
    padding-bottom: 0.15rem;
    transition: color 0.2s ease, border-color 0.2s ease;
    width: fit-content;
  }

  .info-page__contact-link:hover {
    color: rgba(232, 226, 210, 0.85);
    border-color: rgba(232, 226, 210, 0.55);
  }

  @media (max-width: 749px) {
    .info-page {
      height: auto;
      min-height: calc(100dvh - 6rem);
      align-items: flex-start;
      justify-content: flex-start;
      padding: 1rem 1.1rem calc(1.25rem + var(--maw-mobile-nav-clearance, 4rem) + env(safe-area-inset-bottom, 0px));
      box-sizing: border-box;
    }

    .info-page__frame {
      height: auto;
      align-items: flex-start;
      overflow: visible;
    }

    .info-page__track {
      flex-direction: column;
      width: 100%;
      max-width: none;
      gap: 1.35rem;
      align-items: stretch;
      justify-content: flex-start;
    }

    .info-page__card {
      width: min(300px, 86vw);
      max-width: 100%;
      align-self: center;
      order: 0;
    }

    .info-page__img-wrapper {
      aspect-ratio: 1 / 1;
      overflow: visible;
    }

    .info-page__frame-img {
      transform: translate(-51%, -50%) scale(1.14);
    }

    .info-page__arrow {
      display: none !important;
    }

    .info-page__bio {
      flex: none;
      order: 1;
      max-width: none;
      padding: 0;
      justify-content: flex-start;
      gap: 1.1rem;
    }
  }
</style>

<script>
  (function () {
    var wrapper = document.getElementById('info-page-img-wrapper-{{ section.id }}');
    if (!wrapper) return;

    var imgs    = wrapper.querySelectorAll('.info-page__img');
    var prevBtn = wrapper.querySelector('[data-arrow="prev"]');
    var nextBtn = wrapper.querySelector('[data-arrow="next"]');
    if (imgs.length <= 1) return;

    var current = 0;
    var swipeMQ = window.matchMedia('(max-width: 749px)');
    var swipeStartX = 0;
    var swipeStartY = 0;
    var swipeTracking = false;
    var autoDelayMs = 6000;
    var autoTimer = null;

    function goTo(index) {
      imgs[current].classList.remove('is-active');
      current = index;
      imgs[current].classList.add('is-active');
    }

    function goPrev() {
      goTo(current === 0 ? imgs.length - 1 : current - 1);
    }

    function goNext() {
      goTo(current === imgs.length - 1 ? 0 : current + 1);
    }

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      autoTimer = setInterval(function () {
        if (!document.hidden) goNext();
      }, autoDelayMs);
    }

    if (prevBtn) prevBtn.addEventListener('click', goPrev);
    if (nextBtn) nextBtn.addEventListener('click', goNext);

    var SWIPE_MIN = 45;

    wrapper.addEventListener('touchstart', function (e) {
      if (!swipeMQ.matches || e.touches.length !== 1) return;
      swipeTracking = true;
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
    }, { passive: true });

    wrapper.addEventListener('touchmove', function (e) {
      if (!swipeTracking || !swipeMQ.matches) return;
      var t = e.touches[0];
      var dx = t.clientX - swipeStartX;
      var dy = t.clientY - swipeStartY;
      if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 12) swipeTracking = false;
    }, { passive: true });

    wrapper.addEventListener('touchend', function (e) {
      if (!swipeTracking || !swipeMQ.matches) {
        swipeTracking = false;
        return;
      }
      swipeTracking = false;
      var t = e.changedTouches[0];
      var dx = t.clientX - swipeStartX;
      var dy = t.clientY - swipeStartY;
      if (Math.abs(dx) < SWIPE_MIN || Math.abs(dx) < Math.abs(dy)) return;
      if (dx > 0) goPrev();
      else if (dx < 0) goNext();
    }, { passive: true });

    wrapper.addEventListener('touchcancel', function () {
      swipeTracking = false;
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Info page",
  "settings": [
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "makayla wray"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline / role",
      "default": "designer & maker"
    },
    {
      "type": "richtext",
      "id": "bio",
      "label": "Bio / experience",
      "default": "<p>Based in [city], Makayla Wray is a self-taught designer and maker whose practice spans textile design, slow fashion, and wearable art.</p><p>Each piece is made to order from her studio, drawing on years of experience working with natural materials and an obsessive attention to construction.</p>"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "checkbox",
      "id": "show_instagram",
      "label": "Show Instagram icon",
      "default": true
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/moomoomaw/"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Instagram link label (accessibility)",
      "default": "Instagram — @moomoomaw"
    },
    {
      "type": "header",
      "content": "Contact link"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact link label",
      "default": "get in touch"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact link URL"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slideshow image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Info page" }
  ]
}
{% endschema %}
