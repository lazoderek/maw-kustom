<header
  class="site-header"
  x-data
  :class="{ 'site-header--scrolled': $store.header?.scrolled }"
  data-section-id="{{ section.id }}"
  data-section-type="header"
>
  <div class="site-header__inner container">

    <!-- Hamburger (mobile + desktop menu trigger) -->
    <button
      class="site-header__menu-btn"
      @click="$store.menu.toggle()"
      :aria-expanded="$store.menu.open"
      aria-label="Open navigation"
    >
      <span class="site-header__menu-icon" :class="{ 'is-open': $store.menu.open }">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <!-- Wordmark / logo -->
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 280 }}"
          alt="{{ shop.name }}"
          width="140"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="site-header__wordmark">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Right actions -->
    <div class="site-header__actions">
      <button
        class="site-header__icon-btn"
        @click="$store.search.toggle()"
        :aria-expanded="$store.search.open"
        aria-label="Search"
      >
        {%- render 'icon-search' -%}
      </button>

      <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>

      <button
        class="site-header__icon-btn site-header__cart-btn"
        @click="$store.cart.toggle()"
        :aria-expanded="$store.cart.open"
        aria-label="Cart"
      >
        {%- render 'icon-bag' -%}
        <span
          class="site-header__cart-count"
          data-cart-count
          hidden
          aria-live="polite"
        >0</span>
      </button>
    </div>
  </div>

  <!-- Full-screen navigation overlay -->
  <nav
    class="site-nav"
    :class="{ 'site-nav--open': $store.menu.open }"
    aria-label="Main navigation"
    aria-hidden="!$store.menu.open"
  >
    <div class="site-nav__inner">
      <ul class="site-nav__list">
        {%- for link in section.settings.menu.links -%}
          <li class="site-nav__item" style="--i: {{ forloop.index }}">
            {%- if link.links != blank -%}
              <details class="site-nav__details">
                <summary class="site-nav__link site-nav__link--parent">
                  {{ link.title }}
                  <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                    <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  </svg>
                </summary>
                <ul class="site-nav__sub-list">
                  {%- for child in link.links -%}
                    <li><a href="{{ child.url }}" class="site-nav__sub-link">{{ child.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </details>
            {%- else -%}
              <a href="{{ link.url }}" class="site-nav__link" {% if link.active %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      <div class="site-nav__footer">
        <p class="site-nav__tagline">{{ section.settings.nav_tagline | default: 'Handmade with intention.' }}</p>
        <div class="site-nav__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>
          {%- endif -%}
        </div>
      </div>

      <!-- Close button -->
      <button
        class="site-nav__close"
        @click="$store.menu.close()"
        aria-label="Close navigation"
      >
        {%- render 'icon-close' -%}
      </button>
    </div>
  </nav>

  <!-- Search overlay -->
  <div
    class="site-search"
    :class="{ 'site-search--open': $store.search.open }"
    x-trap="$store.search.open"
  >
    <form action="{{ routes.search_url }}" method="get" role="search" class="site-search__form">
      <input type="hidden" name="type" value="product">
      <input
        class="site-search__input"
        type="search"
        name="q"
        placeholder="Search pieces…"
        aria-label="Search"
        autocomplete="off"
      >
      <button type="submit" class="site-search__submit" aria-label="Submit search">
        {%- render 'icon-search' -%}
      </button>
    </form>
    <button class="site-search__close" @click="$store.search.close()" aria-label="Close search">
      {%- render 'icon-close' -%}
    </button>
  </div>
</header>

<style>
  /* ── Header layout ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: 1.25rem;
    transition: background 0.4s ease, padding 0.4s ease;
    mix-blend-mode: normal;
  }

  .site-header--scrolled {
    background: rgba(250, 248, 244, 0.94);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding-block: 0.75rem;
    border-bottom: 1px solid rgba(17, 17, 16, 0.06);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  /* ── Logo / wordmark ── */
  .site-header__logo {
    grid-column: 2;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .site-header__wordmark {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  /* ── Menu button ── */
  .site-header__menu-btn {
    grid-column: 1;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  .site-header__menu-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;
  }

  .site-header__menu-icon span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-ink);
    transition: transform 0.35s var(--ease-smooth), opacity 0.2s;
    transform-origin: center;
  }

  .site-header__menu-icon.is-open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-header__menu-icon.is-open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .site-header__menu-icon.is-open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Actions ── */
  .site-header__actions {
    grid-column: 3;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .site-header__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    position: relative;
    color: var(--color-ink);
  }

  .site-header__icon-btn svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
  }

  .site-header__cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    background: var(--color-stitch);
    color: var(--color-cream);
    font-size: 0.6rem;
    font-weight: 600;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Full-screen nav overlay ── */
  .site-nav {
    position: fixed;
    inset: 0;
    background: var(--color-ink);
    z-index: 99;
    display: flex;
    align-items: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-smooth);
  }

  .site-nav--open {
    opacity: 1;
    pointer-events: all;
  }

  .site-nav__inner {
    width: 100%;
    padding: 5rem clamp(1.5rem, 5vw, 5rem);
    position: relative;
  }

  .site-nav__list {
    list-style: none;
  }

  .site-nav__item {
    overflow: hidden;
    transform: translateY(30px);
    opacity: 0;
    transition:
      transform 0.5s var(--ease-out-expo) calc(var(--i) * 0.07s),
      opacity   0.4s ease                 calc(var(--i) * 0.07s);
  }

  .site-nav--open .site-nav__item {
    transform: translateY(0);
    opacity: 1;
  }

  .site-nav__link {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 6rem);
    color: var(--color-cream);
    line-height: 1.15;
    transition: color 0.2s;
    font-style: italic;
  }

  .site-nav__link:hover,
  .site-nav__link[aria-current="page"] {
    color: var(--color-dust);
  }

  .site-nav__details summary { list-style: none; }
  .site-nav__details summary::-webkit-details-marker { display: none; }

  .site-nav__sub-list {
    list-style: none;
    padding-left: 2rem;
    margin-top: 0.5rem;
  }

  .site-nav__sub-link {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-dust);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .site-nav__sub-link:hover {
    color: var(--color-cream);
  }

  .site-nav__footer {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 2rem;
  }

  .site-nav__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-dust);
    font-size: 1rem;
  }

  .site-nav__social {
    display: flex;
    gap: 1.5rem;
  }

  .site-nav__social a {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dust);
    transition: color 0.2s;
  }

  .site-nav__social a:hover { color: var(--color-cream); }

  .site-nav__close {
    position: absolute;
    top: 1.5rem;
    right: clamp(1.5rem, 5vw, 5rem);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-cream);
    padding: 0.5rem;
  }

  .site-nav__close svg {
    width: 28px;
    height: 28px;
    stroke: currentColor;
    fill: none;
  }

  /* ── Search overlay ── */
  .site-search {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: var(--color-cream);
    padding: 1.5rem clamp(1.25rem, 4vw, 4rem);
    z-index: 98;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--color-dust);
    transform: translateY(-100%);
    transition: transform 0.4s var(--ease-out-expo);
  }

  .site-search--open {
    transform: translateY(0);
  }

  .site-search__form {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-search__input {
    flex: 1;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-ink);
    padding: 0.5rem 0;
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    color: var(--color-ink);
    outline: none;
  }

  .site-search__input::placeholder { color: var(--color-dust); }

  .site-search__submit,
  .site-search__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
    display: flex;
    align-items: center;
    padding: 0.25rem;
  }

  .site-search__submit svg,
  .site-search__close svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
  }
</style>

<script>
  // Header scroll state — updates Alpine store
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof Alpine === 'undefined') return;

      const header = document.querySelector('.site-header');
      if (!header) return;

      const onScroll = () => {
        const scrolled = window.scrollY > 60;
        if (header.classList.contains('site-header--scrolled') !== scrolled) {
          header.classList.toggle('site-header--scrolled', scrolled);
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use your store name as a wordmark."
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    },
    {
      "type": "text",
      "id": "nav_tagline",
      "label": "Nav footer tagline",
      "default": "Handmade with intention."
    }
  ]
}
{% endschema %}
