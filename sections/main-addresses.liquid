<section class="account-page section" data-section-id="{{ section.id }}">
  <div class="container" style="max-width:720px;">
    <h1 class="account-page__title" data-reveal="up">Addresses</h1>

    {%- for address in customer.addresses -%}
      <div class="address-card" data-reveal="up" data-reveal-delay="{{ forloop.index | times: 0.08 }}">
        <address class="address-card__body">{{ address | format_address }}</address>
        {%- if customer.default_address.id == address.id -%}
          <span class="address-card__default">Default</span>
        {%- endif -%}
        <div class="address-card__actions">
          <a href="{{ routes.account_addresses_url }}/{{ address.id }}" class="auth-form__link">Edit</a>
          {%- form 'customer_address', address, class: 'address-card__delete-form' -%}
            <input type="hidden" name="_method" value="delete">
            <button type="submit" class="auth-form__link" onclick="return confirm('Delete this address?')">Delete</button>
          {%- endform -%}
        </div>
      </div>
    {%- endfor -%}

    <div class="address-new" data-reveal="up">
      <h2 class="account-page__section-title" style="margin-top:3rem;">Add new address</h2>
      {%- form 'customer_address', customer.new_address, class: 'auth-form' -%}
        {{ form | default_address_fields: include_blank: false }}
        <button type="submit" class="btn btn--primary" style="align-self:flex-start;">Save address</button>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .address-card { border: 1px solid var(--color-chalk); padding: 1.5rem; margin-bottom: 1rem; display: flex; gap: 1rem; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; }
  .address-card__body { font-style: normal; font-size: 0.9rem; line-height: 1.8; color: var(--color-ink-soft); flex: 1; }
  .address-card__default { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-stitch); border: 1px solid var(--color-stitch); padding: 0.2rem 0.5rem; align-self: flex-start; }
  .address-card__actions { display: flex; gap: 1rem; align-items: center; }
  .address-card__delete-form { display: inline; }
</style>

{% schema %}{ "name": "Customer Addresses", "settings": [] }{% endschema %}
