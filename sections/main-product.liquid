{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image  = current_variant.featured_image | default: product.featured_image

  assign is_inquiry = false
  assign is_configurator = false
  assign is_standard = true

  if product.tags contains 'inquiry'
    assign is_inquiry = true
    assign is_standard = false
  elsif product.tags contains 'custom-configurator'
    assign is_configurator = true
    assign is_standard = false
  endif
-%}

<article
  class="product-page"
  data-section-id="{{ section.id }}"
  data-section-type="main-product"
  itemscope
  itemtype="https://schema.org/Product"
>

  <!-- ── Gallery ── -->
  <div class="product-page__gallery" x-data="{ active: 0 }">
    <div class="product-page__main-image" data-parallax-wrap>
      {%- for image in product.images limit: 8 -%}
        <div class="product-page__slide" x-show="active === {{ forloop.index0 }}" x-transition:enter="fade-in" x-transition:leave="fade-out">
          <img
            src="{{ image | image_url: width: 1400 }}"
            alt="{{ image.alt | default: product.title | escape }}"
            width="{{ image.width }}"
            height="{{ image.height }}"
            loading="{{ forloop.first | default: 'eager' | replace: 'true', 'eager' | replace: 'false', 'lazy' }}"
            itemprop="image"
          >
        </div>
      {%- else -%}
        <div class="product-page__slide">
          <div class="product-card__image-placeholder"></div>
        </div>
      {%- endfor -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="product-page__thumbs">
        {%- for image in product.images limit: 8 -%}
          <button
            class="product-page__thumb"
            @click="active = {{ forloop.index0 }}"
            :class="{ 'is-active': active === {{ forloop.index0 }} }"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | default: product.title | escape }}"
              loading="lazy"
              width="100"
              height="120"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- ── Info ── -->
  <div class="product-page__info">

    <!-- Breadcrumb -->
    <nav class="product-page__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">·</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">·</span>
      {%- endif -%}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <!-- Type badge -->
    {%- if is_inquiry -%}
      <span class="product-page__type-badge">Inquiry & made-to-order</span>
    {%- elsif is_configurator -%}
      <span class="product-page__type-badge">Custom configurator</span>
    {%- else -%}
      {%- for tag in product.tags -%}
        {%- if tag contains 'made-to-order' -%}
          <span class="product-page__type-badge">Made to order</span>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    <h1 class="product-page__title" itemprop="name" data-reveal="up">{{ product.title }}</h1>

    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
      <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.0 }}">
      {%- render 'product-price', product: product -%}
    </div>

    <!-- Description -->
    {%- if product.description != blank -%}
      <div class="product-page__description rte" data-reveal="up" data-reveal-delay="0.1" itemprop="description">
        {{ product.description }}
      </div>
    {%- endif -%}

    <hr class="product-page__divider">

    <!-- ── Standard SKU form ── -->
    {%- if is_standard -%}
      {%- form 'product', product, id: 'product-form', class: 'product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          <div class="product-form__variants">
            {%- for option in product.options_with_values -%}
              <fieldset class="product-form__option">
                <legend class="product-form__option-label">
                  {{ option.name }}
                  <span class="product-form__selected-value" id="option-{{ forloop.index }}-value">
                    {{ option.selected_value }}
                  </span>
                </legend>
                <div class="product-form__option-values">
                  {%- for value in option.values -%}
                    <label class="product-form__pill">
                      <input
                        type="radio"
                        name="{{ option.name }}"
                        value="{{ value }}"
                        {% if option.selected_value == value %}checked{% endif %}
                        class="visually-hidden"
                        onchange="updateVariant(this)"
                      >
                      <span class="product-form__pill-label">{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="product-form__submit-wrap">
          <button
            type="submit"
            name="add"
            class="btn btn--primary product-form__add"
            {% if current_variant.available == false %}disabled{% endif %}
          >
            {%- if current_variant.available -%}
              Add to bag
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}
    {%- endif -%}

    <!-- ── Inquiry form ── -->
    {%- if is_inquiry -%}
      <div class="inquiry-form" x-data="{ submitted: false, loading: false }">
        <p class="inquiry-form__intro">
          This piece is made to order. Send a request and Makayla will be in touch within 2–3 business days to discuss fit, timeline, and materials.
        </p>
        {%- form 'contact', id: 'inquiry-form', class: 'inquiry-form__form' -%}
          <input type="hidden" name="contact[body]" value="— Inquiry for: {{ product.title }} ({{ product.url | prepend: shop.secure_url }})">
          <div class="inquiry-form__row">
            <label for="inquiry-name">Name</label>
            <input type="text" id="inquiry-name" name="contact[name]" required>
          </div>
          <div class="inquiry-form__row">
            <label for="inquiry-email">Email</label>
            <input type="email" id="inquiry-email" name="contact[email]" required>
          </div>
          <div class="inquiry-form__row">
            <label for="inquiry-details">Details</label>
            <textarea id="inquiry-details" name="contact[details]" rows="4" placeholder="Your measurements, occasion, any special requests…"></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send request</button>
          {%- if form.posted_successfully? -%}
            <p class="inquiry-form__success">Request sent — Makayla will be in touch soon.</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    <!-- ── Custom configurator ── -->
    {%- if is_configurator -%}
      <div class="configurator" x-data="configurator()" x-init="init()">

        <!-- Step indicators -->
        <div class="configurator__steps">
          <template x-for="(step, i) in steps" :key="i">
            <div
              class="configurator__step-dot"
              :class="{ 'is-active': currentStep === i, 'is-done': currentStep > i }"
            >
              <span x-text="i + 1"></span>
            </div>
          </template>
        </div>

        <form id="configurator-form">
          <input type="hidden" name="id" :value="variantId">

          <!-- Step: Measurements -->
          <div x-show="currentStep === 0">
            <h3 class="configurator__step-title">Measurements</h3>
            <p class="configurator__step-hint">Measure in inches. Not sure? <a href="/pages/size-guide" class="btn--text">Size guide →</a></p>
            <div class="configurator__fields">
              <div class="configurator__field">
                <label for="cfg-bust">Bust</label>
                <input type="number" id="cfg-bust" x-model="form.bust" name="properties[Bust (in)]" placeholder="e.g. 36" min="20" max="70" step="0.5" required>
              </div>
              <div class="configurator__field">
                <label for="cfg-waist">Waist</label>
                <input type="number" id="cfg-waist" x-model="form.waist" name="properties[Waist (in)]" placeholder="e.g. 28" min="16" max="60" step="0.5" required>
              </div>
              <div class="configurator__field">
                <label for="cfg-hip">Hip</label>
                <input type="number" id="cfg-hip" x-model="form.hip" name="properties[Hip (in)]" placeholder="e.g. 38" min="20" max="70" step="0.5" required>
              </div>
              <div class="configurator__field">
                <label for="cfg-height">Height</label>
                <input type="text" id="cfg-height" x-model="form.height" name="properties[Height]" placeholder="e.g. 5'6&quot;">
              </div>
            </div>
          </div>

          <!-- Step: Fabric -->
          <div x-show="currentStep === 1">
            <h3 class="configurator__step-title">Fabric choice</h3>
            {%- if product.metafields.custom.fabric_options != blank -%}
              <div class="configurator__swatches">
                {%- assign fabrics = product.metafields.custom.fabric_options.value -%}
                {%- for fabric in fabrics -%}
                  <label
                    class="configurator__swatch-label"
                    :class="{ 'is-selected': form.fabric === '{{ fabric }}' }"
                  >
                    <input type="radio" x-model="form.fabric" name="properties[Fabric]" value="{{ fabric }}" class="visually-hidden">
                    <span>{{ fabric }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="configurator__field">
                <label for="cfg-fabric">Describe your fabric preference</label>
                <input type="text" id="cfg-fabric" x-model="form.fabric" name="properties[Fabric preference]" placeholder="e.g. linen, silk, cotton…">
              </div>
            {%- endif -%}
          </div>

          <!-- Step: Notes -->
          <div x-show="currentStep === 2">
            <h3 class="configurator__step-title">Final notes</h3>
            <div class="configurator__field">
              <label for="cfg-notes">Any additional requests?</label>
              <textarea id="cfg-notes" x-model="form.notes" name="properties[Notes]" rows="4" placeholder="Lining preference, special occasion, delivery date…"></textarea>
            </div>
          </div>

          <!-- Navigation -->
          <div class="configurator__nav">
            <button type="button" class="btn btn--ghost" x-show="currentStep > 0" @click="prev()">← Back</button>
            <button type="button" class="btn btn--primary" x-show="currentStep < steps.length - 1" @click="next()">Next →</button>
            <button
              type="button"
              class="btn btn--primary"
              x-show="currentStep === steps.length - 1"
              @click="submit()"
              :disabled="loading"
              x-text="loading ? 'Adding…' : 'Add to bag'"
            ></button>
          </div>
        </form>

        <p class="configurator__error" x-show="error" x-text="error" style="color:var(--color-stitch);margin-top:1rem;font-size:0.85rem;"></p>
      </div>
    {%- endif -%}

    <!-- Collapsible details -->
    {%- if product.metafields.custom.materials != blank or product.metafields.custom.care != blank -%}
      <div class="product-page__details">
        {%- if product.metafields.custom.materials != blank -%}
          <details class="product-detail">
            <summary>Materials</summary>
            <div class="product-detail__body">{{ product.metafields.custom.materials }}</div>
          </details>
        {%- endif -%}
        {%- if product.metafields.custom.care != blank -%}
          <details class="product-detail">
            <summary>Care instructions</summary>
            <div class="product-detail__body">{{ product.metafields.custom.care }}</div>
          </details>
        {%- endif -%}
        <details class="product-detail">
          <summary>Shipping & returns</summary>
          <div class="product-detail__body">
            {%- if product.metafields.custom.shipping_info != blank -%}
              {{ product.metafields.custom.shipping_info }}
            {%- else -%}
              Made-to-order pieces ship within 2–4 weeks. All sales are final on custom orders. Standard items may be exchanged within 14 days.
            {%- endif -%}
          </div>
        </details>
      </div>
    {%- endif -%}

  </div>
</article>

<style>
  .product-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    padding-top: 72px;
  }

  @media (max-width: 900px) {
    .product-page { grid-template-columns: 1fr; }
  }

  /* ── Gallery ── */
  .product-page__gallery {
    position: relative;
    background: var(--color-chalk);
  }

  .product-page__main-image {
    position: sticky;
    top: 72px;
    height: calc(100svh - 72px);
    overflow: hidden;
  }

  .product-page__slide {
    position: absolute;
    inset: 0;
  }

  .product-page__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .product-page__thumbs {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }

  .product-page__thumb {
    width: 50px;
    height: 60px;
    overflow: hidden;
    border: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition: border-color 0.2s;
    padding: 0;
  }

  .product-page__thumb.is-active {
    border-color: var(--color-ink);
  }

  .product-page__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Info panel ── */
  .product-page__info {
    padding: clamp(2rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 600px;
  }

  .product-page__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-dust);
    font-family: var(--font-sans);
  }

  .product-page__breadcrumb a:hover { color: var(--color-ink); }

  .product-page__type-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stitch);
    border: 1px solid var(--color-stitch);
    padding: 0.25rem 0.6rem;
    border-radius: 1px;
    align-self: flex-start;
  }

  .product-page__title {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    line-height: 1.1;
  }

  .product-page__description {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-ink-soft);
  }

  .product-page__description p + p { margin-top: 0.75em; }

  .product-page__divider {
    border: none;
    border-top: 1px solid var(--color-chalk);
  }

  /* ── Variant pills ── */
  .product-form__option { border: none; padding: 0; margin-bottom: 1.25rem; }

  .product-form__option-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dust);
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .product-form__selected-value {
    color: var(--color-ink);
    font-weight: 500;
  }

  .product-form__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-form__pill input:checked + .product-form__pill-label {
    background: var(--color-ink);
    color: var(--color-cream);
    border-color: var(--color-ink);
  }

  .product-form__pill-label {
    display: inline-block;
    padding: 0.45rem 1rem;
    border: 1px solid var(--color-chalk);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 1px;
  }

  .product-form__pill-label:hover {
    border-color: var(--color-ink);
  }

  .product-form__submit-wrap { margin-top: 1.5rem; }

  .product-form__add {
    width: 100%;
    justify-content: center;
    padding: 1.1rem;
  }

  /* ── Inquiry form ── */
  .inquiry-form__intro {
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }

  .inquiry-form__form,
  .configurator__fields {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .inquiry-form__row,
  .configurator__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .inquiry-form__row label,
  .configurator__field label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dust);
  }

  .inquiry-form__row input,
  .inquiry-form__row textarea,
  .configurator__field input,
  .configurator__field textarea {
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-chalk);
    padding: 0.5rem 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink);
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }

  .inquiry-form__row input:focus,
  .inquiry-form__row textarea:focus,
  .configurator__field input:focus,
  .configurator__field textarea:focus {
    border-color: var(--color-ink);
  }

  .inquiry-form__row input::placeholder,
  .configurator__field input::placeholder,
  .configurator__field textarea::placeholder {
    color: var(--color-dust);
  }

  .inquiry-form__form .btn { margin-top: 1rem; }

  .inquiry-form__success {
    margin-top: 1rem;
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-stitch);
  }

  /* ── Configurator ── */
  .configurator__steps {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .configurator__step-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-chalk);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-dust);
    transition: all 0.3s;
  }

  .configurator__step-dot.is-active {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .configurator__step-dot.is-done {
    border-color: var(--color-stitch);
    background: var(--color-stitch);
    color: var(--color-cream);
  }

  .configurator__step-title {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .configurator__step-hint {
    font-size: 0.85rem;
    color: var(--color-dust);
    margin-bottom: 1.25rem;
  }

  .configurator__fields { margin-bottom: 1.5rem; }

  .configurator__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .configurator__swatch-label {
    cursor: pointer;
  }

  .configurator__swatch-label span {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--color-chalk);
    font-size: 0.85rem;
    transition: all 0.2s;
    border-radius: 1px;
  }

  .configurator__swatch-label.is-selected span {
    background: var(--color-ink);
    color: var(--color-cream);
    border-color: var(--color-ink);
  }

  .configurator__nav {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  /* ── Collapsible details ── */
  .product-page__details {
    margin-top: 0.5rem;
    border-top: 1px solid var(--color-chalk);
  }

  .product-detail {
    border-bottom: 1px solid var(--color-chalk);
  }

  .product-detail summary {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1rem 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .product-detail summary::-webkit-details-marker { display: none; }

  .product-detail summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 300;
    transition: transform 0.25s;
  }

  .product-detail[open] summary::after {
    transform: rotate(45deg);
  }

  .product-detail__body {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-ink-soft);
    padding-bottom: 1.25rem;
  }
</style>

<script>
  function configurator() {
    return {
      steps: ['Measurements', 'Fabric', 'Notes'],
      currentStep: 0,
      loading: false,
      error: null,
      variantId: {{ product.first_available_variant.id | json }},
      form: { bust: '', waist: '', hip: '', height: '', fabric: '', notes: '' },

      init() {},

      next() {
        if (this.currentStep < this.steps.length - 1) this.currentStep++;
      },

      prev() {
        if (this.currentStep > 0) this.currentStep--;
      },

      async submit() {
        this.loading = true;
        this.error = null;
        const formEl = document.getElementById('configurator-form');
        const data = new FormData(formEl);

        const properties = {};
        data.forEach((val, key) => {
          if (key.startsWith('properties[')) {
            const prop = key.replace('properties[', '').replace(']', '');
            properties[prop] = val;
          }
        });

        try {
          await window.MAWCart.add({
            id: this.variantId,
            quantity: 1,
            properties,
          });
          window.location.href = '/cart';
        } catch (e) {
          this.error = 'Something went wrong — please try again.';
          this.loading = false;
        }
      },
    };
  }

  // Variant change handler for standard products
  function updateVariant(el) {
    // Minimal variant selection — finds matching variant and updates price/id
    const form = el.closest('form');
    const options = {};
    form.querySelectorAll('input[type="radio"]:checked').forEach((r) => {
      options[r.name] = r.value;
    });

    const variants = {{ product.variants | json }};
    const match = variants.find((v) => {
      return v.options.every((opt, i) => opt === options[{{ product.options | json }}[i]]);
    });

    if (match) {
      form.querySelector('input[name="id"]').value = match.id;
      const addBtn = form.querySelector('[name="add"]');
      if (addBtn) {
        addBtn.disabled = !match.available;
        addBtn.textContent = match.available ? 'Add to bag' : 'Sold out';
      }
    }
  }
</script>

{% schema %}
{
  "name": "Product page",
  "settings": [],
  "blocks": [
    { "type": "title",   "name": "Title",   "limit": 1, "settings": [] },
    { "type": "price",   "name": "Price",   "limit": 1, "settings": [] },
    { "type": "text",    "name": "Text",    "settings": [{ "type": "richtext", "id": "text", "label": "Text" }] },
