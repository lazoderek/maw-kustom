<section class="auth-page section" data-section-id="{{ section.id }}">
  <div class="container" style="max-width:480px;">
    <h1 class="auth-page__title" data-reveal="up">Sign in</h1>

    {%- form 'customer_login', class: 'auth-form' -%}
      {%- if form.errors -%}
        <div class="auth-form__errors">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="auth-form__field">
        <label for="email">Email</label>
        <input type="email" id="email" name="customer[email]" autocomplete="email" required
               value="{{ form.email }}">
      </div>
      <div class="auth-form__field">
        <label for="password">Password</label>
        <input type="password" id="password" name="customer[password]" autocomplete="current-password" required>
      </div>

      <div class="auth-form__actions">
        <button type="submit" class="btn btn--primary">Sign in</button>
        <a href="{{ routes.root_url }}account/login#recover" class="auth-form__link">Forgot password?</a>
      </div>
    {%- endform -%}

    <p class="auth-page__alt">
      New here? <a href="{{ routes.account_register_url }}" class="auth-form__link">Create an account →</a>
    </p>
  </div>
</section>

{%- style -%}
  .auth-page { padding-top: calc(72px + 5rem); padding-bottom: 6rem; }
  .auth-page__title { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2.5rem; }
  .auth-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .auth-form__errors { color: var(--color-stitch); font-size: 0.85rem; margin-bottom: 0.5rem; }
  .auth-form__field { display: flex; flex-direction: column; gap: 0.35rem; }
  .auth-form__field label { font-family: var(--font-sans); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-dust); }
  .auth-form__field input { background: none; border: none; border-bottom: 1px solid var(--color-chalk); padding: 0.6rem 0; font-size: 1rem; color: var(--color-ink); outline: none; transition: border-color 0.2s; width: 100%; }
  .auth-form__field input:focus { border-color: var(--color-ink); }
  .auth-form__actions { display: flex; align-items: center; gap: 1.5rem; margin-top: 0.5rem; }
  .auth-form__link { font-size: 0.78rem; color: var(--color-dust); border-bottom: 1px solid currentColor; transition: color 0.2s; }
  .auth-form__link:hover { color: var(--color-ink); }
  .auth-page__alt { margin-top: 2rem; font-size: 0.9rem; color: var(--color-dust); }
{%- endstyle -%}

{% schema %}{ "name": "Customer Login", "settings": [] }{% endschema %}
