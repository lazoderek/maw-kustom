<section class="collections-list section" data-section-id="{{ section.id }}">
  <div class="container">
    <h1 class="collections-list__title" data-reveal="up">
      {{ section.settings.title | default: 'Collections' }}
    </h1>

    <div class="collections-list__grid" data-reveal="up" data-reveal-stagger="0.08">
      {%- for collection in collections -%}
        <article class="collection-card" data-reveal-child>
          <a href="{{ collection.url }}" class="collection-card__link" aria-label="{{ collection.title }}">
            <div class="collection-card__image-wrap">
              {%- if collection.image -%}
                <img
                  src="{{ collection.image | image_url: width: 800 }}"
                  alt="{{ collection.image.alt | default: collection.title | escape }}"
                  loading="lazy"
                >
              {%- elsif collection.products.first.featured_image -%}
                <img
                  src="{{ collection.products.first.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="product-card__image-placeholder"></div>
              {%- endif -%}
              <div class="collection-card__overlay"></div>
            </div>
            <div class="collection-card__info">
              <h2 class="collection-card__title">{{ collection.title }}</h2>
              <span class="collection-card__count">{{ collection.products_count }} pieces</span>
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collections-list {
    padding-top: calc(72px + 4rem);
  }

  .collections-list__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 3rem;
  }

  .collections-list__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .collection-card__link { display: block; }

  .collection-card__image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-chalk);
    margin-bottom: 1rem;
  }

  .collection-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-smooth);
  }

  .collection-card:hover .collection-card__image-wrap img {
    transform: scale(1.04);
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,16,0.4) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .collection-card:hover .collection-card__overlay { opacity: 1; }

  .collection-card__info {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .collection-card__title {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    transition: color 0.2s;
  }

  .collection-card:hover .collection-card__title { color: var(--color-stitch); }

  .collection-card__count {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-dust);
    white-space: nowrap;
  }
</style>

{% schema %}
{
  "name": "Collections list",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Collections" }
  ]
}
{% endschema %}
