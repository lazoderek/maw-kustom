{% comment %}
  Home hero — single full-bleed image filling the viewport above the nav-banner.
{% endcomment %}

<section class="home-hero" data-section-id="{{ section.id }}">
  <div class="home-hero__frame">
    {%- if section.settings.image != blank -%}
      <img
        class="home-hero__img"
        src="{{ section.settings.image | image_url: width: 2400 }}"
        srcset="
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1800 }} 1800w,
          {{ section.settings.image | image_url: width: 2400 }} 2400w,
          {{ section.settings.image | image_url: width: 3200 }} 3200w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: shop.name }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>
</section>

<style>
  .home-hero {
    width: 100%;
    /* Match #MainContent: flex child already spans viewport minus bottom nav */
    height: 100%;
    min-height: 0;
    padding: clamp(1rem, 3vw, 3rem);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 749px) {
    .home-hero {
      /* Full bleed left/right; breathe away from top/bottom of the content window */
      padding: clamp(0.625rem, 2.5vmin, 1.25rem) 0;
    }
  }

  .home-hero__frame {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  .home-hero__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "presets": [
    { "name": "Home hero" }
  ]
}
{% endschema %}