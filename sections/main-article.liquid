<article class="article-page" data-section-id="{{ section.id }}" itemscope itemtype="https://schema.org/Article">
  {%- if article.image -%}
    <div class="article-page__hero" data-parallax-wrap>
      <div class="article-page__hero-image" data-parallax="0.3">
        <img
          src="{{ article.image | image_url: width: 2000 }}"
          alt="{{ article.image.alt | default: article.title | escape }}"
          loading="eager"
          itemprop="image"
        >
      </div>
    </div>
  {%- endif -%}

  <div class="container container--narrow article-page__inner">
    <header class="article-page__header" data-reveal="up">
      <a href="{{ blog.url }}" class="article-page__back btn--text">← {{ blog.title }}</a>
      <time class="article-page__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
        {{ article.published_at | date: '%B %d, %Y' }}
      </time>
      <h1 class="article-page__title" itemprop="name">{{ article.title }}</h1>
    </header>

    <div class="article-page__body rte" itemprop="articleBody" data-reveal="up" data-reveal-delay="0.1">
      {{ article.content }}
    </div>

    {%- if article.tags.size > 0 -%}
      <footer class="article-page__footer">
        <div class="article-page__tags">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-page__tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      </footer>
    {%- endif -%}
  </div>
</article>

<style>
  .article-page__hero {
    position: relative;
    height: 60svh;
    overflow: hidden;
    background: var(--color-chalk);
    margin-top: 72px;
  }

  .article-page__hero-image {
    position: absolute;
    inset: -10%;
  }

  .article-page__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-page__inner {
    padding-top: clamp(3rem, 6vw, 6rem);
    padding-bottom: 6rem;
  }

  .article-page__header { margin-bottom: 3rem; }

  .article-page__back {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dust);
    border-bottom: 1px solid currentColor;
    margin-bottom: 1.5rem;
  }

  .article-page__date {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dust);
    margin-bottom: 0.75rem;
  }

  .article-page__title { font-size: clamp(2rem, 4.5vw, 3.5rem); }

  .article-page__body {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
  }

  .article-page__body h2 { margin: 2em 0 0.75em; }
  .article-page__body h3 { margin: 1.5em 0 0.5em; }
  .article-page__body p  { margin-bottom: 1.1em; }
  .article-page__body img { max-width: 100%; margin: 2em 0; }
  .article-page__body blockquote {
    border-left: 3px solid var(--color-stitch);
    padding-left: 1.5rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-ink);
    margin: 2em 0;
  }

  .article-page__footer { margin-top: 3rem; border-top: 1px solid var(--color-chalk); padding-top: 2rem; }

  .article-page__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .article-page__tag {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-dust);
    border: 1px solid var(--color-chalk);
    padding: 0.25rem 0.65rem;
    border-radius: 1px;
    transition: all 0.2s;
  }

  .article-page__tag:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
</style>

{% schema %}
{
  "name": "Article page",
  "settings": []
}
{% endschema %}
