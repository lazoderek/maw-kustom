<section class="hero" data-section-id="{{ section.id }}" data-section-type="hero-editorial">

  <!-- Background image with parallax -->
  {%- if section.settings.bg_image != blank -%}
    <div class="hero__bg" data-parallax-wrap>
      <div class="hero__bg-inner" data-parallax="0.4">
        <img
          src="{{ section.settings.bg_image | image_url: width: 2400 }}"
          alt="{{ section.settings.bg_image.alt | default: shop.name }}"
          width="{{ section.settings.bg_image.width }}"
          height="{{ section.settings.bg_image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      </div>
    </div>
  {%- else -%}
    <div class="hero__bg hero__bg--fallback"></div>
  {%- endif -%}

  <!-- Noise texture overlay -->
  <div class="texture-overlay"></div>

  <!-- Scrapbook floating elements -->
  <div class="hero__scrapbook" aria-hidden="true">

    {%- for block in section.blocks -%}
      {%- if block.type == 'scrapbook_asset' -%}
        <div
          class="hero__asset hero__asset--{{ block.settings.asset_type }}"
          style="
            --asset-top:    {{ block.settings.pos_top  }}%;
            --asset-left:   {{ block.settings.pos_left }}%;
            --asset-rotate: {{ block.settings.rotation }}deg;
            --asset-scale:  {{ block.settings.scale | divided_by: 100.0 }};
            --asset-delay:  {{ block.settings.anim_delay | divided_by: 10.0 }}s;
          "
          data-floater="{{ block.settings.parallax_speed | divided_by: 100.0 }}"
          {{ block.shopify_attributes }}
        >
          {%- case block.settings.asset_type -%}
            {%- when 'tape' -%}
              <div class="scrap-tape" style="--tape-color: {{ block.settings.tint_color }};"></div>

            {%- when 'stitch' -%}
              <svg class="scrap-stitch" viewBox="0 0 120 8" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 4 Q10 0 20 4 Q30 8 40 4 Q50 0 60 4 Q70 8 80 4 Q90 0 100 4 Q110 8 120 4"
                  fill="none" stroke="{{ block.settings.tint_color | default: '#8C5E4A' }}" stroke-width="2" stroke-dasharray="4 3"/>
              </svg>

            {%- when 'swatch' -%}
              {%- if block.settings.swatch_image != blank -%}
                <div class="scrap-swatch">
                  <img
                    src="{{ block.settings.swatch_image | image_url: width: 300 }}"
                    alt="{{ block.settings.swatch_image.alt }}"
                    loading="lazy"
                    width="150"
                  >
                </div>
              {%- else -%}
                <div class="scrap-swatch scrap-swatch--color" style="background: {{ block.settings.tint_color | default: '#C8B8A2' }};"></div>
              {%- endif -%}

            {%- when 'text_clip' -%}
              <div class="scrap-text-clip" style="--clip-color: {{ block.settings.tint_color | default: '#FAF8F4' }};">
                <span>{{ block.settings.clip_text | default: 'Made by hand' }}</span>
              </div>

            {%- when 'zipper' -%}
              <svg class="scrap-zipper" viewBox="0 0 16 80" xmlns="http://www.w3.org/2000/svg">
                <line x1="8" y1="0" x2="8" y2="80" stroke="{{ block.settings.tint_color | default: '#111110' }}" stroke-width="2"/>
                {%- for t in (1..8) -%}
                  {%- assign y = forloop.index | times: 9 -%}
                  <rect x="3" y="{{ y }}" width="10" height="4" rx="1" fill="{{ block.settings.tint_color | default: '#111110' }}" opacity="0.7"/>
                {%- endfor -%}
                <rect x="2" y="2" width="12" height="6" rx="2" fill="{{ block.settings.tint_color | default: '#8C5E4A' }}"/>
              </svg>

          {%- endcase -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <!-- Main content -->
  <div class="hero__content container">
    <div class="hero__text-wrap">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow" data-reveal="up" data-reveal-delay="0.1">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      <h1 class="hero__headline" data-reveal="up" data-reveal-delay="0.2">
        {%- if section.settings.headline_line_2 != blank -%}
          <span class="hero__headline-line">{{ section.settings.headline_line_1 | default: 'Wear what' }}</span>
          <span class="hero__headline-line hero__headline-line--italic">{{ section.settings.headline_line_2 }}</span>
        {%- else -%}
          {{ section.settings.headline_line_1 | default: 'Wear what you feel.' }}
        {%- endif -%}
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="hero__subtext" data-reveal="up" data-reveal-delay="0.35">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}

      <div class="hero__ctas" data-reveal="up" data-reveal-delay="0.5">
        {%- if section.settings.cta_1_label != blank -%}
          <a href="{{ section.settings.cta_1_url }}" class="btn btn--primary">
            {{ section.settings.cta_1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_2_label != blank -%}
          <a href="{{ section.settings.cta_2_url }}" class="btn btn--text hero__cta-text">
            {{ section.settings.cta_2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-hint" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-label">Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-cream);
  }

  /* ── Background ── */
  .hero__bg {
    position: absolute;
    inset: -10%;
    z-index: 0;
  }

  .hero__bg-inner {
    width: 100%;
    height: 100%;
  }

  .hero__bg-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__bg--fallback {
    background: linear-gradient(135deg, var(--color-chalk) 0%, var(--color-cream) 60%, var(--color-dust) 100%);
    opacity: 0.5;
  }

  /* ── Scrapbook floating layer ── */
  .hero__scrapbook {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .hero__asset {
    position: absolute;
    top: var(--asset-top, 50%);
    left: var(--asset-left, 50%);
    transform: rotate(var(--asset-rotate, 0deg)) scale(var(--asset-scale, 1));
    animation: assetPop 0.6s var(--ease-out-expo) var(--asset-delay, 0s) both;
  }

  @keyframes assetPop {
    from { opacity: 0; transform: rotate(var(--asset-rotate, 0deg)) scale(calc(var(--asset-scale, 1) * 0.6)); }
    to   { opacity: 1; transform: rotate(var(--asset-rotate, 0deg)) scale(var(--asset-scale, 1)); }
  }

  /* Scrapbook elements */
  .scrap-tape {
    width: clamp(80px, 12vw, 180px);
    height: clamp(20px, 3vw, 40px);
    background: var(--tape-color, rgba(200, 184, 162, 0.55));
    border-radius: 2px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.06);
  }

  .scrap-stitch {
    width: clamp(80px, 14vw, 200px);
    height: auto;
  }

  .scrap-swatch {
    width: clamp(80px, 12vw, 160px);
    height: clamp(100px, 16vw, 200px);
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  .scrap-swatch img { width: 100%; height: 100%; object-fit: cover; }

  .scrap-swatch--color { opacity: 0.7; }

  .scrap-text-clip {
    background: var(--clip-color);
    padding: 0.4rem 0.9rem;
    border-radius: 1px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    transform-origin: center;
  }

  .scrap-text-clip span {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(0.75rem, 1.2vw, 1rem);
    color: var(--color-ink);
    white-space: nowrap;
  }

  .scrap-zipper {
    width: 16px;
    height: clamp(60px, 10vw, 120px);
  }

  /* ── Content ── */
  .hero__content {
    position: relative;
    z-index: 3;
    padding-top: 7rem;
    padding-bottom: 5rem;
    width: 100%;
  }

  .hero__text-wrap {
    max-width: 750px;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-stitch);
    margin-bottom: 1.25rem;
  }

  .hero__headline {
    display: block;
    margin-bottom: 1.5rem;
  }

  .hero__headline-line {
    display: block;
  }

  .hero__headline-line--italic {
    font-style: italic;
    color: var(--color-stitch);
  }

  .hero__subtext {
    max-width: 44ch;
    margin-bottom: 2.5rem;
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.8;
  }

  .hero__ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero__cta-text {
    color: var(--color-ink-soft);
  }

  /* ── Scroll hint ── */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-ink);
    animation: scrollPulse 1.8s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes scrollPulse {
    0%   { transform: scaleY(0); opacity: 0; }
    40%  { transform: scaleY(1); opacity: 1; }
    80%  { transform: scaleY(1); opacity: 0; }
    100% { transform: scaleY(0); opacity: 0; }
  }

  .hero__scroll-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
</style>

{% schema %}
{
  "name": "Editorial Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Makayla Wray Studio"
    },
    {
      "type": "text",
      "id": "headline_line_1",
      "label": "Headline — line 1",
      "default": "Wear what"
    },
    {
      "type": "text",
      "id": "headline_line_2",
      "label": "Headline — line 2 (italic / accent)",
      "default": "you feel."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Custom garments designed and sewn by hand, made to order from our studio."
    },
    {
      "type": "text",
      "id": "cta_1_label",
      "label": "Primary CTA label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_1_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_2_label",
      "label": "Secondary CTA label",
      "default": "View portfolio"
    },
    {
      "type": "url",
      "id": "cta_2_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    }
  ],
  "blocks": [
    {
      "type": "scrapbook_asset",
      "name": "Scrapbook Asset",
      "settings": [
        {
          "type": "select",
          "id": "asset_type",
          "label": "Asset type",
          "options": [
            { "value": "tape",      "label": "Tape strip" },
            { "value": "stitch",    "label": "Stitch line" },
            { "value": "swatch",    "label": "Fabric swatch" },
            { "value": "text_clip", "label": "Text clip" },
            { "value": "zipper",    "label": "Zipper" }
          ],
          "default": "tape"
        },
        {
          "type": "image_picker",
          "id": "swatch_image",
          "label": "Swatch image (for 'Fabric swatch' type)"
        },
        {
          "type": "text",
          "id": "clip_text",
          "label": "Clip text (for 'Text clip' type)",
          "default": "Made by hand"
        },
        {
          "type": "color",
          "id": "tint_color",
          "label": "Color / tint",
          "default": "#C8B8A2"
        },
        {
          "type": "range",
          "id": "pos_top",
          "label": "Position — top %",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 20
        },
        {
          "type": "range",
          "id": "pos_left",
          "label": "Position — left %",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 75
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation (degrees)",
          "min": -45,
          "max": 45,
          "step": 1,
          "default": -8
        },
        {
          "type": "range",
          "id": "scale",
          "label": "Scale %",
          "min": 30,
          "max": 200,
          "step": 5,
          "default": 100
        },
        {
          "type": "range",
          "id": "anim_delay",
          "label": "Animation delay (× 0.1s)",
          "min": 0,
          "max": 20,
          "step": 1,
          "default": 3
        },
        {
          "type": "range",
          "id": "parallax_speed",
          "label": "Parallax speed (0 = none, 100 = fast)",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Hero",
      "blocks": [
        {
          "type": "scrapbook_asset",
          "settings": {
            "asset_type": "tape",
            "tint_color": "#C8B8A2",
            "pos_top": 15,
            "pos_left": 68,
            "rotation": -6,
            "scale": 110,
            "anim_delay": 4,
            "parallax_speed": 30
          }
        },
        {
          "type": "scrapbook_asset",
          "settings": {
            "asset_type": "stitch",
            "tint_color": "#8C5E4A",
            "pos_top": 35,
            "pos_left": 72,
            "rotation": 3,
            "scale": 90,
            "anim_delay": 6,
            "parallax_speed": 60
          }
        },
        {
          "type": "scrapbook_asset",
          "settings": {
            "asset_type": "text_clip",
            "clip_text": "Made by hand",
            "tint_color": "#FAF8F4",
            "pos_top": 60,
            "pos_left": 62,
            "rotation": 4,
            "scale": 100,
            "anim_delay": 8,
            "parallax_speed": 45
          }
        },
        {
          "type": "scrapbook_asset",
          "settings": {
            "asset_type": "zipper",
            "tint_color": "#111110",
            "pos_top": 25,
            "pos_left": 88,
            "rotation": 15,
            "scale": 120,
            "anim_delay": 5,
            "parallax_speed": 25
          }
        }
      ]
    }
  ]
}
{% endschema %}
