{% comment %}
  All-products: horizontal drag-scroll on desktop; mobile matches Info/Studio — full width, vertical stack, page scroll on #MainContent.
{% endcomment %}

<section class="all-products" data-section-id="{{ section.id }}">
  <div class="all-products__frame" id="all-products-frame">
    <div class="all-products__track" id="all-products-track">

      {%- for product in collection.products -%}
        {%- assign product_is_first = forloop.first -%}
        {%- comment -%} Frames frame-2 … frame-4 (n+1 offset vs gallery); cycles for longer collections. {%- endcomment -%}
        {%- assign product_frame_i = forloop.index0 | modulo: 3 | plus: 2 -%}
        <div class="all-products__card" draggable="false">
          
          <div class="all-products__img-wrapper">
            {%- for image in product.images -%}
              <img
                class="all-products__img{% if forloop.first %} is-active{% endif %}"
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {%- else -%}
              <div class="all-products__placeholder"></div>
            {%- endfor -%}

            <img
              class="all-products__frame-img"
              src="{{ 'frame-' | append: product_frame_i | append: '.png' | asset_url }}"
              alt=""
              aria-hidden="true"
              loading="{% if product_is_first %}eager{% else %}lazy{% endif %}"
            >

            {%- if product.images.size > 1 -%}
              <button class="all-products__arrow all-products__arrow--prev" type="button" aria-label="Previous image" data-arrow="prev" hidden>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11L5 7l4-4"/></svg>
              </button>
              <button class="all-products__arrow all-products__arrow--next" type="button" aria-label="Next image" data-arrow="next">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l4 4-4 4"/></svg>
              </button>
            {%- endif -%}
          </div>

          <div class="all-products__info">
            <div class="all-products__head-row">
              <div class="all-products__text-group">
                <span class="all-products__title">{{ product.title }}</span>
                <span class="all-products__price">{{ product.price | money }}</span>
              </div>

              <div class="all-products__options-wrap">
                {%- unless product.has_only_default_variant -%}
                  <div class="all-products__options">
                    {%- for option in product.options_with_values -%}
                      <div class="all-products__option-group">
                        <label class="all-products__option-label" for="option-{{ product.id }}-{{ forloop.index }}">
                          {{- option.name | downcase -}}
                        </label>
                        <div class="all-products__select-wrap">
                          <select class="all-products__option-select" id="option-{{ product.id }}-{{ forloop.index }}" name="options[{{ option.name | escape }}]" data-product-id="{{ product.id }}" data-option-index="{{ forloop.index0 }}">
                            {%- for value in option.values -%}
                              <option value="{{ value | escape }}">{{ value | escape }}</option>
                            {%- endfor -%}
                          </select>
                          <svg class="all-products__select-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l3 3 3-3"/></svg>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endunless -%}
              </div>
            </div>

            {%- comment -%} Rich HTML (links, paragraphs). Typography locked via .all-products__description descendant rules. {%- endcomment -%}
            <div class="all-products__description">
              {{ product.description }}
            </div>

            <button class="all-products__add-btn" type="button" aria-label="Add to cart">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <line x1="7" y1="1" x2="7" y2="13"/>
                <line x1="1" y1="7" x2="13" y2="7"/>
              </svg>
            </button>
          </div>
          
        </div>
      {%- endfor -%}

      {%- if collection.products.size == 0 -%}
        <div class="all-products__empty">
          <p>No pieces yet — check back soon.</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  /* Make the Shopify section wrapper fill #MainContent exactly */
  #shopify-section-{{ section.id }} {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* ── Horizontal scroll track ── */
  .all-products__track {
    display: flex;
    height: 100%;
    /* Gap + card inline padding: frames scale past the card box; need real air between visuals */
    gap: clamp(2rem, 6vw, 4rem);
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    align-items: stretch;
    overscroll-behavior-x: contain;
    padding-inline: clamp(0.5rem, 2vw, 1.25rem);
    box-sizing: border-box;
  }

  /* ── Card: open panel like Info / Studio (no brown slab behind copy) ── */
  .all-products__card {
    flex-shrink: 0;
    height: 100%;
    width: clamp(300px, 42vw, 620px);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: transparent;
    padding: 0 clamp(0.85rem, 2.5vw, 1.75rem);
    box-sizing: border-box;
    position: relative;
    transition: transform 0.3s ease;
    user-select: none;
    -webkit-user-select: none;
  }

  /* ── The Square Image Crop ── */
  .all-products {
    width: 100%;
    height: calc(100vh - clamp(2rem, 6vw, 6rem));
    padding: clamp(1rem, 3vw, 3rem) clamp(1rem, 3vw, 3rem) 0;
    box-sizing: border-box;
    display: flex;
  }

  .all-products__frame {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .all-products__img-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    flex-shrink: 0;
    overflow: visible;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    position: relative;
  }

  .all-products__placeholder {
    position: absolute;
    inset: 0;
    background: rgba(232, 226, 210, 0.06);
    border-radius: 4px;
  }

  .all-products__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .all-products__img.is-active {
    opacity: 1;
  }

  .all-products__frame-img {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 5;
    display: block;
    /* Between tight crop (~1.06) and info/studio drama (~1.35) */
    transform: translate(-50%, -50%) scale(1.18);
  }

  /* ── Image gallery arrows ── */
  .all-products__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(13, 10, 7, 0.6);
    border: 1px solid rgba(232, 226, 210, 0.18);
    color: #e8e2d2;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease;
    z-index: 6;
    padding: 0;
  }

  .all-products__img-wrapper:hover .all-products__arrow:not([hidden]) {
    opacity: 1;
  }

  @media (hover: none) {
    .all-products__img-wrapper .all-products__arrow:not([hidden]) {
      opacity: 0.88;
    }
  }

  .all-products__arrow:hover {
    background: rgba(13, 10, 7, 0.88);
  }

  .all-products__arrow--prev { left: 0.6rem; }
  .all-products__arrow--next { right: 0.6rem; }

  /* ── Info: typography aligned with Info / Studio bio column ── */
  .all-products__info {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: clamp(0.5rem, 1.2vw, 0.85rem);
    padding: 0 0.15rem;
    min-height: 0;
  }

  .all-products__title {
    font-family: 'TTHoves', sans-serif;
    font-size: clamp(0.95rem, 1.35vw, 1.15rem);
    font-weight: 400;
    color: #e8e2d2;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .all-products__description {
    font-size: clamp(0.72rem, 1vw, 0.88rem);
    line-height: 1.75;
    color: rgba(232, 226, 210, 0.92);
    margin: 0;
    min-width: 0;
    user-select: text;
    -webkit-user-select: text;
  }

  /* Neutralize RTE/browser defaults so markup matches the former plain-text card */
  .all-products__description :where(p, li, span, div, blockquote) {
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
  }

  .all-products__description p {
    margin: 0 0 0.65em;
  }

  .all-products__description p:last-child {
    margin-bottom: 0;
  }

  .all-products__description ul,
  .all-products__description ol {
    margin: 0 0 0.65em;
    padding-left: 1.15em;
    color: inherit;
  }

  .all-products__description strong,
  .all-products__description b {
    font-weight: 600;
    color: inherit;
  }

  .all-products__description em,
  .all-products__description i {
    font-style: italic;
    color: inherit;
  }

  /* Same cream as body copy — underline only (no default link blue) */
  .all-products__description a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(232, 226, 210, 0.35);
    text-underline-offset: 0.18em;
  }

  .all-products__description a:hover {
    text-decoration-color: rgba(232, 226, 210, 0.65);
  }

  .all-products__price {
    font-size: clamp(0.72rem, 1vw, 0.85rem);
    letter-spacing: 0.06em;
    color: rgba(232, 226, 210, 0.72);
    margin: 0;
    text-transform: lowercase;
  }

  /* ── Title + options row (desktop); mobile grid splits via display:contents ── */
  .all-products__head-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .all-products__options-wrap {
    flex-shrink: 0;
  }

  /* ── Option dropdowns ── */
  .all-products__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    flex-shrink: 0;
  }

  .all-products__option-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .all-products__option-label {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(232, 226, 210, 0.72);
    text-transform: lowercase;
  }

  .all-products__text-group {
    display: flex;
    flex-direction: column;
    gap: 0.1rem; /* Adjust this for the exact tightness you want */
  }

  .all-products__select-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .all-products__option-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 1px solid rgba(232, 226, 210, 0.22);
    color: #e8e2d2;
    font-family: 'TTHoves', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    padding: 0.3rem 1.8rem 0.3rem 0.65rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    min-width: 80px;
  }

  .all-products__option-select option {
    background: #271f16;
    color: #e8e2d2;
  }

  .all-products__option-select:hover,
  .all-products__option-select:focus {
    border-color: rgba(232, 226, 210, 0.55);
    background: rgba(232, 226, 210, 0.05);
  }

  .all-products__select-chevron {
    position: absolute;
    right: 0.5rem;
    color: rgba(232, 226, 210, 0.45);
    pointer-events: none;
    flex-shrink: 0;
  }

  .all-products__add-btn {
    align-self: center;
    margin-top: 0.35rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(232, 226, 210, 0.35);
    color: #e8e2d2;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }
  .all-products__add-btn:hover {
    background: rgba(232, 226, 210, 0.08);
    border-color: rgba(232, 226, 210, 0.65);
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      height: auto;
      min-height: 0;
    }

    .all-products {
      height: auto;
      min-height: calc(100dvh - 6rem);
      align-items: flex-start;
      justify-content: flex-start;
      padding: 1rem 1.1rem calc(1.25rem + var(--maw-mobile-nav-clearance, 4rem) + env(safe-area-inset-bottom, 0px));
      box-sizing: border-box;
    }

    .all-products__frame {
      flex: none;
      width: 100%;
      height: auto;
      overflow: visible;
    }

    .all-products__track {
      flex-direction: column;
      width: 100%;
      max-width: none;
      height: auto;
      gap: clamp(1.75rem, 5vw, 2.75rem);
      overflow-x: hidden;
      overflow-y: visible;
      padding-inline: 0;
      align-items: stretch;
    }

    .all-products__card {
      width: 100%;
      max-width: 100%;
      height: auto;
      padding-inline: 0;
    }

    .all-products__info {
      padding: 0;
      display: grid;
      /* Col 2 sizes to controls; description spans full width below with padding for + */
      grid-template-columns: minmax(0, 1fr) minmax(0, max-content);
      grid-template-rows: auto auto;
      column-gap: 0.55rem;
      row-gap: 0.65rem;
      align-items: start;
    }

    .all-products__head-row {
      display: contents;
    }

    .all-products__text-group {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
    }

    .all-products__options-wrap {
      grid-column: 2;
      grid-row: 1;
      justify-self: stretch;
      text-align: right;
      min-width: 0;
      max-width: 100%;
    }

    .all-products__options {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: stretch;
      justify-content: flex-end;
      gap: 0.35rem;
      width: 100%;
      min-width: 0;
    }

    .all-products__option-group {
      flex: 1 1 0;
      min-width: 0;
      align-items: stretch;
    }

    .all-products__option-group:only-child {
      flex: 0 0 auto;
      max-width: 100%;
      align-self: flex-end;
    }

    .all-products__option-group:only-child .all-products__select-wrap {
      width: auto;
      max-width: min(7rem, 52vw);
    }

    .all-products__option-group:only-child .all-products__option-select {
      width: auto;
      min-width: 3.85rem;
      max-width: 100%;
    }

    .all-products__option-label {
      font-size: 0.52rem;
      letter-spacing: 0.06em;
      line-height: 1.2;
    }

    .all-products__select-wrap {
      width: 100%;
      max-width: 100%;
    }

    .all-products__option-select {
      font-size: 0.56rem;
      letter-spacing: 0.01em;
      padding: 0.18rem 1.05rem 0.18rem 0.35rem;
      min-width: 0;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }

    .all-products__select-chevron {
      width: 8px;
      height: 8px;
      right: 0.3rem;
    }

    .all-products__description {
      grid-column: 1 / -1;
      grid-row: 2;
      min-width: 0;
      /* Full-width copy; reserve only the + control (no whole option-column gutter) */
      padding-right: calc(36px + 0.45rem);
      box-sizing: border-box;
    }

    .all-products__add-btn {
      grid-column: 2;
      grid-row: 2;
      align-self: start;
      justify-self: end;
      margin-top: 0;
      position: relative;
      z-index: 1;
    }

    /* Photo sits slightly inside the decorative frame (tape border visible as mat) */
    .all-products__img {
      top: 6%;
      left: 6%;
      width: 88%;
      height: 88%;
    }

    .all-products__placeholder {
      inset: auto;
      top: 6%;
      left: 6%;
      width: 88%;
      height: 88%;
    }

    .all-products__frame-img {
      transform: translate(-50%, -50%) scale(1.1);
    }

    .all-products__arrow {
      display: none !important;
    }
  }
</style>

<script>
  (function () {
    const frame = document.getElementById('all-products-frame');
    const track = document.getElementById('all-products-track');
    if (!frame || !track) return;

    const mqDesktop = window.matchMedia('(min-width: 750px)');

    let isDragging  = false;
    let startX      = 0;
    let scrollStart = 0;
    let dragMoved   = false;

    const DRAG_THRESHOLD = 6; // px before we call it a drag vs. a click

    frame.addEventListener('mousedown', (e) => {
      if (!mqDesktop.matches) return;
      if (e.target.closest('a[href]')) return;
      isDragging  = true;
      dragMoved   = false;
      startX      = e.pageX;
      scrollStart = track.scrollLeft;
      track.style.scrollBehavior = 'auto';
      frame.classList.add('is-dragging');
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging || !mqDesktop.matches) return;
      const delta = startX - e.pageX;
      if (Math.abs(delta) > DRAG_THRESHOLD) dragMoved = true;
      track.scrollLeft = scrollStart + delta;
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      frame.classList.remove('is-dragging');
      track.style.scrollBehavior = 'smooth';
    });

    /* Prevent navigating to the product if the user was dragging */
    track.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', (e) => {
        if (dragMoved) {
          e.preventDefault();
          dragMoved = false;
        }
      });
    });

    /* Touch: horizontal track scroll only on desktop layout */
    let touchStartX      = 0;
    let touchScrollStart = 0;

    track.addEventListener('touchstart', (e) => {
      if (!mqDesktop.matches) return;
      if (e.target.closest('a[href]')) return;
      touchStartX      = e.touches[0].pageX;
      touchScrollStart = track.scrollLeft;
      track.style.scrollBehavior = 'auto';
    }, { passive: true });

    track.addEventListener('touchmove', (e) => {
      if (!mqDesktop.matches) return;
      const delta = touchStartX - e.touches[0].pageX;
      track.scrollLeft = touchScrollStart + delta;
    }, { passive: true });

    track.addEventListener('touchend', () => {
      if (!mqDesktop.matches) return;
      track.style.scrollBehavior = 'smooth';
    });

    const swipeMQ = window.matchMedia('(max-width: 749px)');
    const SWIPE_MIN = 45;

    /* ── Image gallery cycling (+ swipe on mobile, arrows hidden) ── */
    track.querySelectorAll('.all-products__img-wrapper').forEach((wrapper) => {
      const imgs    = wrapper.querySelectorAll('.all-products__img');
      const prevBtn = wrapper.querySelector('[data-arrow="prev"]');
      const nextBtn = wrapper.querySelector('[data-arrow="next"]');
      if (imgs.length <= 1) return;

      let current = 0;

      function goTo(index) {
        imgs[current].classList.remove('is-active');
        current = index;
        imgs[current].classList.add('is-active');
        if (prevBtn) prevBtn.hidden = current === 0;
        if (nextBtn) nextBtn.hidden = current === imgs.length - 1;
      }

      function goPrev() {
        if (current > 0) goTo(current - 1);
      }

      function goNext() {
        if (current < imgs.length - 1) goTo(current + 1);
      }

      prevBtn && prevBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        goPrev();
      });

      nextBtn && nextBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        goNext();
      });

      let swipeTracking = false;
      let swipeStartX = 0;
      let swipeStartY = 0;

      wrapper.addEventListener('touchstart', (e) => {
        if (!swipeMQ.matches || e.touches.length !== 1) return;
        swipeTracking = true;
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
      }, { passive: true });

      wrapper.addEventListener('touchmove', (e) => {
        if (!swipeTracking || !swipeMQ.matches) return;
        const t = e.touches[0];
        const dx = t.clientX - swipeStartX;
        const dy = t.clientY - swipeStartY;
        if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 12) swipeTracking = false;
      }, { passive: true });

      wrapper.addEventListener('touchend', (e) => {
        if (!swipeTracking || !swipeMQ.matches) {
          swipeTracking = false;
          return;
        }
        swipeTracking = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - swipeStartX;
        const dy = t.clientY - swipeStartY;
        if (Math.abs(dx) < SWIPE_MIN || Math.abs(dx) < Math.abs(dy)) return;
        if (dx > 0) goPrev();
        else if (dx < 0) goNext();
      }, { passive: true });

      wrapper.addEventListener('touchcancel', () => {
        swipeTracking = false;
      }, { passive: true });
    });
  })();
</script>

{% schema %}
{
  "name": "All products scroll",
  "settings": [],
  "presets": [
    { "name": "All products scroll" }
  ]
}
{% endschema %}
