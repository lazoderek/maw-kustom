<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#FAF8F4">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64, height: 64 }}">
  {%- endif -%}
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100svh;padding:2rem;">
  <div style="text-align:center;max-width:480px;">
    <a href="{{ routes.root_url }}" style="font-family:var(--font-serif);font-size:2rem;letter-spacing:0.25em;text-transform:uppercase;display:block;margin-bottom:3rem;">
      {{ shop.name }}
    </a>
    {{ content_for_layout }}
  </div>
</body>
</html>
