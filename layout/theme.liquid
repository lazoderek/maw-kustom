<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
  {%- assign _chrome = settings.browser_chrome_color | default: '#271f16' -%}
  {%- comment -%} Android Chrome, older Safari; Safari 26+ mostly samples fixed strips (see theme.css). {%- endcomment -%}
  <meta name="theme-color" content="{{ _chrome }}" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="{{ _chrome }}" media="(prefers-color-scheme: dark)">
  <style id="maw-browser-chrome">
    :root { --maw-safari-chrome: {{ _chrome }}; }
  </style>
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64, height: 64 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} — tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} — Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} — {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>

  <!-- Google Fonts: Cormorant Garamond (editorial serif) + DM Sans (body) -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

  <!-- Compiled Tailwind CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Shopify required hook (apps, analytics, etc.) -->
  {{ content_for_header }}

  <script>
    // Expose Shopify routes for JS
    window.MAW = {
      shopUrl: '{{ request.origin }}',
      routes: {
        cart:           '{{ routes.cart_url }}',
        cart_add:       '{{ routes.cart_add_url }}',
        cart_change:    '{{ routes.cart_change_url }}',
        cart_update:    '{{ routes.cart_update_url }}',
        predictive_search: '{{ routes.predictive_search_url }}'
      },
      strings: {
        addToCart:   {{ 'products.product.add_to_cart' | t | json }},
        soldOut:     {{ 'products.product.sold_out' | t | json }},
        unavailable: {{ 'products.product.unavailable' | t | json }}
      }
    };
    // Remove no-js class early to avoid FOUC
    document.documentElement.classList.remove('no-js');
    if (Shopify.designMode) {
      document.documentElement.classList.add('shopify-design-mode');
    }
  </script>
</head>

<body x-data class="no-js:hidden">

  {%- comment -%} Safari 26+: fixed strips (top + bottom) — meta theme-color is ignored. {%- endcomment -%}
  <div class="safari-chrome-tint safari-chrome-tint--top" aria-hidden="true"></div>

  <!-- Skip to content (accessibility) -->
  <a class="skip-link" href="#MainContent">Skip to content</a>

  <!-- Scrollable content window (info/studio: single scroll on main, not nested section scroll) -->
  <main id="MainContent" class="{% if template.suffix == 'info' or template.suffix == 'studio' %}main--page-scroll{% endif %}" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Fixed bottom navigation bar -->
  {% section 'global-nav' %}

  <div class="safari-chrome-tint safari-chrome-tint--bottom" aria-hidden="true"></div>

  <!-- ── Libraries (CDN, loaded in order) ── -->

  <!-- GSAP core + ScrollTrigger -->
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

  <!--
    Load order matters:
    1. theme.js (defer) registers alpine:init listener BEFORE Alpine initialises
    2. Alpine CDN (defer) fires alpine:init, then processes the DOM
    Defer scripts execute in DOM order, so this sequence is guaranteed.
  -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>

  <!-- Accessibility live region -->
  <div id="a11y-announcer" aria-live="polite" aria-atomic="true" class="visually-hidden"></div>

</body>
</html>
