{%- liquid
  assign target = product | default: variant
  assign compare_price = target.compare_at_price
  assign final_price   = target.price
  assign on_sale = false
  if compare_price and compare_price > final_price
    assign on_sale = true
  endif
-%}

<p class="product-price" {% if on_sale %}data-on-sale{% endif %}>
  {%- if on_sale -%}
    <s class="product-price__compare">{{ compare_price | money }}</s>
  {%- endif -%}
  <span class="product-price__current {% if on_sale %}product-price__current--sale{% endif %}">
    {{ final_price | money }}
  </span>
</p>

<style>
  .product-price {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .product-price__compare {
    color: var(--color-dust);
    text-decoration: line-through;
  }

  .product-price__current { color: var(--color-ink-soft); }

  .product-price__current--sale { color: var(--color-stitch); }
</style>
